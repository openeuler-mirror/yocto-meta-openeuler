 	uint32_t offset[RSC_TABLE_NUM_ENTRY];
@@ -69,6 +78,7 @@ struct fw_resource_table {
 	struct fw_rsc_vdev vdev;
 	struct fw_rsc_vdev_vring vring0;
 	struct fw_rsc_vdev_vring vring1;
+	struct fw_rsc_vring_offset vring_offset;
 #endif
 
 #if defined(CONFIG_RAM_CONSOLE)
@@ -96,6 +106,14 @@ inline struct fw_rsc_vdev_vring *rsc_table_get_vring1(struct fw_resource_table *
