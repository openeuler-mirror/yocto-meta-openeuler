+		req->tv_sec = cpu_to_le64(kts.tv_sec);		/* seconds */
+		req->tv_usec = cpu_to_le64((kts.tv_nsec / HCLGE_NS_PER_US));	/* microseconds */
+		req->flag = cpu_to_le32((u32)SYNC_SET_FLAG);
