+static struct hclge_dev *hclge_get_hclge_dev(int dev_id)
+{
+	struct list_head *ae_dev_list = NULL;
+	struct hnae3_ae_dev *ae_dev2 = NULL;
+	struct hnae3_ae_dev *ae_dev = NULL;
+	struct hclge_dev *hdev = NULL;
+
+	if (dev_id > MAX_DEV_ID || dev_id < 0) {
+		pr_err("hns3: param error! dev_id = %d, valid dev_id[%d, %d].\n",
+		       dev_id, 0, MAX_DEV_ID);
+		return NULL;
+	}
+
+	ae_dev_list = hnae3_get_ae_dev_list();
+	list_for_each_entry_safe(ae_dev, ae_dev2, ae_dev_list, node) {
+		if (!ae_dev || !ae_dev->priv) {
+			pr_err("hns3: ae_dev or ae_dev->priv is NULL.\n");
+			hdev = NULL;
+			break;
+		}
+
+		hdev = ae_dev->priv;
+		if (hdev->die_id == dev_id)
+			break;
+		hdev = NULL;
+	}
+
+	hnae3_put_ae_dev_list();
+
+	return hdev;
+}
+
+struct pci_dev *hclge_get_pci_dev(int dev_id)
+{
+	struct hclge_dev *hdev = NULL;
+	struct pci_dev *pdev = NULL;
+
+	hdev = hclge_get_hclge_dev(dev_id);
+	if (!hdev) {
+		pr_err("hns3: hclge get hclge dev fail.\n");
+		return NULL;
+	}
+	pdev = hdev->pdev;
+
+	return pdev;
+}
+EXPORT_SYMBOL(hclge_get_pci_dev);
