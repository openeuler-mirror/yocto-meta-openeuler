-{
-	struct hnae3_client *client = hdev->udma_client;
-	struct hnae3_handle *handle = &hdev->udma;
-	int ret;
-
-	if (!test_bit(HCLGEVF_STATE_UDMA_REGISTERED, &hdev->state) || !client)
-		return 0;
