-
-	send_msg.code = HCLGE_MBX_SET_MGUID;
-	if (guid_node->state == HCLGE_COMM_UNIC_ADDR_TO_ADD)
-		send_msg.subcode = HCLGE_MBX_MC_GUID_MC_ADD;
-	else
-		send_msg.subcode = HCLGE_MBX_MC_GUID_MC_DELETE;
