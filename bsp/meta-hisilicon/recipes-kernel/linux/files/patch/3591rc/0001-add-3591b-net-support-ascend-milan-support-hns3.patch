-			if (len - pos < strlen(content)) {
-				spin_unlock_bh(&vport->ip_list_lock);
-				dev_warn(&hdev->pdev->dev,
-					 "Warning: IP list debugfs buffer overflow.\n");
-				return 0;
-			}
-
-			pos += scnprintf(buf + pos, len - pos, "%s", content);
-		}
-		spin_unlock_bh(&vport->ip_list_lock);
-	}
-	return 0;
-}
