-
-	if (!hnae3_dev_udma_supported(ae_dev) || !hdev->udma_client ||
-	    !hdev->nic_client)
-		return 0;
-
-	if (!client->ops->init_instance)
-		return -EOPNOTSUPP;
-
-	ret = hclgevf_init_udma_base_info(hdev);
-	if (ret)
