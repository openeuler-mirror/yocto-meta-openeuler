+#ifdef CONFIG_PM_SLEEP
+static int sdhci_zodiac_suspend(struct device *dev)
+{
+    int ret;
+    struct sdhci_host *host = dev_get_drvdata(dev);
+
+    ret = sdhci_suspend_host(host);
+    if (ret != 0) {
+        return ret;
+    }
+    // 关闭控制器时钟， 并等稳定
+    sdhci_zodiac_disable_clk(host);
+    // 关闭crg时钟门控
+    sdhci_zodiac_icg_dis(host);
+    // 复位控制器
+    sdhci_zodiac_hardware_reset(host);
+    return 0;
+}
+
+static int sdhci_zodiac_resume(struct device *dev)
+{
+    int ret;
+    struct sdhci_host *host = dev_get_drvdata(dev);
+    struct sdhci_pltfm_host *pltfm_host = sdhci_priv(host);
+    struct sdhci_zodiac_host *zodiac_host = sdhci_pltfm_priv(pltfm_host);
+
+    // 解复位控制器
+    ret = sdhci_zodiac_hardware_disreset(host);
+    if (ret != 0) {
+        return ret;
+    }
+    // 使能crg 时钟门控
+    ret = sdhci_zodiac_icg_en(host);
+    if (ret != 0) {
+        return ret;
+    }
+    // 使能控制器时钟 并等稳定
+    sdhci_zodiac_enable_clk(host);
+    // 给颗粒或者卡上电
+    sdhci_zoidac_set_card_power_en(host, 1);
+    // emmc phy 初始化
+
+    if (zodiac_host->host_mode == ZODIAC_EMMC_MODE) {
+        ret = sdhci_combo_phy_init(host);
+        if (ret != 0) {
+            return ret;
+        }
+    }
+    dev_info(dev, "sdhci_zodiac_resume: ios.clock=%d, timing=%d.\n", host->mmc->ios.clock, host->mmc->ios.timing);
+    ret = sdhci_resume_host(host);
+    if (ret != 0) {
+        return ret;
+    }
+    return 0;
+}
+#endif /* CONFIG_PM_SLEEP */
+
+static const struct dev_pm_ops sdhci_zodiac_dev_pm_ops = { SET_SYSTEM_SLEEP_PM_OPS(sdhci_zodiac_suspend,
+    sdhci_zodiac_resume) SET_RUNTIME_PM_OPS(NULL, NULL, NULL) };
+
+static int sdhci_zodiac_get_phy_resource(struct platform_device *pdev)
+{
+    struct sdhci_host *host = platform_get_drvdata(pdev);
+    struct sdhci_pltfm_host *pltfm_host = sdhci_priv(host);
+    struct sdhci_zodiac_host *zodiac_host = sdhci_pltfm_priv(pltfm_host);
+    struct resource *res;
+
+    res = platform_get_resource_byname(pdev, IORESOURCE_MEM, "phy");
+    zodiac_host->phy.io_base = devm_ioremap_resource(&pdev->dev, res);
+    if (IS_ERR(zodiac_host->phy.io_base)) {
+        dev_err(&pdev->dev, "devm_ioremap phy iobase fail\n");
+        return PTR_ERR(zodiac_host->phy.io_base);
+    }
+    zodiac_host->phy.io_size = res->end - res->start + 1;
+    return 0;
+}
+
+static int sdhci_zodiac_parse_clk_cfg(struct platform_device *pdev)
+{
+    struct sdhci_host *host = platform_get_drvdata(pdev);
+    struct sdhci_pltfm_host *pltfm_host = sdhci_priv(host);
+    struct sdhci_zodiac_host *zodiac_host = sdhci_pltfm_priv(pltfm_host);
+    struct device *dev = &pdev->dev;
+    int ret;
+    int i;
+    u8 prop_name[64] = {0}; // 最大64个字符
+
+    for (i = 0; i < HISI_MMC_MAX_TIMING_MODE; i++) {
+        ret = sprintf_s(prop_name, sizeof(prop_name), "timing_%d_cfg", i);
+        if (ret < 0) {
+            dev_err(dev, "sprintf_s fail i = %d\n", i);
+            return -EINVAL;
+        }
+        if (device_property_read_u32_array(dev, prop_name, (u32 *)&zodiac_host->clk_cfg[i],
+            sizeof(zodiac_host->clk_cfg[i]) / sizeof(u32))) {
+            dev_err(dev, "problem parsing timing_%d_cfg property\n", i);
+            return -EINVAL;
+        }
+    }
+    return 0;
+}
+
+static int sdhci_zodiac_get_property(struct platform_device *pdev)
+{
+    struct sdhci_host *host = platform_get_drvdata(pdev);
+    struct sdhci_pltfm_host *pltfm_host = sdhci_priv(host);
+    struct sdhci_zodiac_host *zodiac_host = sdhci_pltfm_priv(pltfm_host);
+    struct device *dev = &pdev->dev;
+    struct device_node *np = dev->of_node;
+    int ret;
+
+    if (of_device_is_compatible(np, "hisilicon,sdhci_emmc")) {
+        zodiac_host->host_mode = ZODIAC_EMMC_MODE;
+    }
+    if (of_device_is_compatible(np, "hisilicon,sdhci_sd")) {
+        zodiac_host->host_mode = ZODIAC_SD_MODE;
+    }
+    if (of_device_is_compatible(np, "hisilicon,sdhci_sdio")) {
+        zodiac_host->host_mode = ZODIAC_SDIO_MODE;
+    }
+    if (of_device_is_compatible(np, "hisilicon,sdhci_emmc_sd")) {
+        if (device_property_read_u32(dev, "host_mode", &zodiac_host->host_mode) != 0) {
+            dev_err(dev, "failed to get sdhci host_mode, ret = %d\n", ret);
+            return -EINVAL;
+        }
+    }
+
+    if (zodiac_host->host_mode > ZODIAC_SDIO_MODE) {
+        dev_err(dev, "host_mode %u err exceed max!\n", zodiac_host->host_mode);
+        return ret;
+    }
+
+    if (device_property_read_u32(dev, "host_id", &zodiac_host->host_id) != 0) {
+        dev_err(dev, "failed to get sdhci host_id, ret = %d\n", ret);
+        return -EINVAL;
+    }
+    if (device_property_read_bool(dev, "broken_hs200")) {
+        host->quirks2 |= SDHCI_QUIRK2_BROKEN_HS200;
+    }
+
+    ret = sdhci_zodiac_parse_clk_cfg(pdev);
+    if (ret != 0) {
+        dev_err(&pdev->dev, "sdhci_zodiac_parse_clk_cfg fail\n");
+        return ret;
+    }
+    if (zodiac_host->host_mode == ZODIAC_EMMC_MODE) {
+        ret = sdhci_zodiac_get_phy_resource(pdev);
+        if (ret != 0) {
+            dev_err(&pdev->dev, "sdhci_zodiac_get_phy_resource fail\n");
+            return ret;
+        }
+    }
+    return 0;
+}
+
+static int sdhci_zodiac_parse_acpi_dts(struct platform_device *pdev)
+{
+    struct sdhci_host *host = platform_get_drvdata(pdev);
+    int ret;
+
+    ret = mmc_of_parse(host->mmc);
+    if (ret != 0) { // 框架函数 解析mmc
+        dev_err(&pdev->dev, "mmc_of_parse fail\n");
+        return ret;
+    }
+    sdhci_get_property(pdev);
+    ret = sdhci_zodiac_get_property(pdev);
+    if (ret != 0) {
+        dev_err(&pdev->dev, "sdhci_zodiac_get_property fail\n");
+        return ret;
+    }
+    return 0;
+}
+
+static void sdhci_host_quirks2_cfg(struct sdhci_host *host)
+{
+    host->quirks2 |= SDHCI_QUIRK2_HOST_NO_CMD23;
+    host->quirks |= SDHCI_QUIRK_NO_ENDATTR_IN_NOPDESC;
+    host->mmc->caps2 |= MMC_CAP2_NO_PRESCAN_POWERUP;
+    if (host->mmc->pm_caps & MMC_PM_KEEP_POWER) {
+        host->mmc->pm_flags |= MMC_PM_KEEP_POWER;
+        host->quirks2 |= SDHCI_QUIRK2_HOST_OFF_CARD_ON;
+    }
+
+    if (!(host->quirks2 & SDHCI_QUIRK2_BROKEN_64_BIT_DMA)) {
+        host->dma_mask = DMA_BIT_MASK(64); // 64bit
+    } else {
+        host->dma_mask = DMA_BIT_MASK(32); // 32bit
+    }
+    mmc_dev(host->mmc)->dma_mask = &host->dma_mask;
+}
+
+static void sdhci_zodiac_set_desc_size(struct sdhci_host *host)
+{
+    host->caps = sdhci_readl(host, SDHCI_CAPABILITIES);
+    /* 海思自研控制器amda 32/64bit 描述符大小需为16字节, 框架定义SDHCI_ADMA2_64_DESC_SZ和SDHCI_ADMA2_32_DESC_SZ
+    经分析框架代码64bit可做到不侵入式修改,32bit需侵入式修改, 经评估32bit 64bit仅地址差异，性能无差别，商用不用adma32
+    芯片验证阶段可侵入式修改验证adma32 */
+    if (host->caps & SDHCI_CAN_64BIT) {
+        host->alloc_desc_sz = 16; // 海思自研控制器amda 64bit 描述符大小为16字节, 框架定义为12个字节, 解决侵入式修改
+    }
+}
+
+static int sdhci_zodiac_probe(struct platform_device *pdev)
+{
+    int ret;
+    struct sdhci_host *host = NULL;
+    struct sdhci_zodiac_host *zodiac_host = NULL;
+
+    dev_info(&pdev->dev, "sdhci_zodiac_probe start:\n");
+    host = sdhci_pltfm_init(pdev, &sdhci_zodiac_pdata, sizeof(*zodiac_host));
+    if (IS_ERR(host)) {
+        return PTR_ERR(host);
+    }
+
+    zodiac_host = sdhci_pltfm_priv(sdhci_priv(host));
+    zodiac_host->dev = &pdev->dev;
+    zodiac_host->host = host;
+
+    if (sdhci_zodiac_parse_acpi_dts(pdev) != 0) {
+        goto err_pltfm_free;
+    }
+
+    ret = hisi_mmc_subctrl_init(zodiac_host->host_mode, zodiac_host->host_id, zodiac_host->dev);
+    if (ret != 0) {
+        goto err_pltfm_free;
+    }
+
+    ret = sdhci_zodiac_get_clk_rst_info(zodiac_host);
+    if (ret != 0) {
+        goto err_pltfm_free;
+    }
+
+    // 复位解复位 使能时钟门控 phy初始化等
+    ret = sdhci_zodiac_init_cfg(host);
+    if (ret != 0) {
+        goto err_pltfm_free;
+    }
+
+    sdhci_host_quirks2_cfg(host);
+    sdhci_zodiac_set_desc_size(host);
+    ret = sdhci_add_host(host);
+    if (ret != 0) {
+        goto err_pltfm_free;
+    }
+
+    dev_info(&pdev->dev, "%s: sdhci_zodiac_probe done! \n", dev_name(zodiac_host->dev));
+    return 0;
+
+err_pltfm_free:
+    sdhci_pltfm_free(pdev);
+    dev_err(&pdev->dev, "sdhci_zodiac_probe fail!! ret = %d!\n", ret);
+    return ret;
+}
+
+static int sdhci_zodiac_remove(struct platform_device *pdev)
+{
+    struct sdhci_host *host = platform_get_drvdata(pdev);
+
+    dev_info(&pdev->dev, "sdhci_zodiac_remove\n");
+    sdhci_remove_host(host, 1);
+    sdhci_zodiac_icg_dis(host);
+    // 给卡或者颗粒下电
+    sdhci_zoidac_set_card_power_en(host, 0);
+    sdhci_pltfm_free(pdev);
+    return 0;
+}
+
+static const struct of_device_id sdhci_zodiac_of_match[] = {
+    {.compatible = "hisilicon,sdhci_emmc_sd"}, // 二合一控制器，解析dts host_mode
+    {.compatible = "hisilicon,sdhci_emmc"},
+    {.compatible = "hisilicon,sdhci_sd"},
+    {.compatible = "hisilicon,sdhci_sdio"},
+    {}
+};
+
+MODULE_DEVICE_TABLE(of, sdhci_zodiac_of_match);
+
+static struct platform_driver sdhci_zodiac_driver = {
+    .driver = {
+        .name = "sdhci_zodiac",
+        .of_match_table = sdhci_zodiac_of_match,
+        .pm = &sdhci_zodiac_dev_pm_ops,
+    },
+    .probe = sdhci_zodiac_probe,
+    .remove = sdhci_zodiac_remove,
+};
+
+module_platform_driver(sdhci_zodiac_driver);
+
+MODULE_DESCRIPTION("Driver for the zodiac SDHCI Controller");
+MODULE_AUTHOR("zodiac");
+MODULE_LICENSE("GPL");
