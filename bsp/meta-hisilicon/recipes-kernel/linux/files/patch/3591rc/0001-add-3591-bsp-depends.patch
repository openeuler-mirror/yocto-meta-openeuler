+				(mrq->cmd->data->stop &&
+					mrq->cmd->data->stop->error))))) {
+		/* if SD get hardware timeout, No tuning move! */
+		if (host->sd_hw_timeout == 1) {
+			host->sd_hw_timeout = 0;
+			return;
