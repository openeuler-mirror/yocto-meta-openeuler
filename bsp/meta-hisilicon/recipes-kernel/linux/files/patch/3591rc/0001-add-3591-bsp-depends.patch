+static inline int dw_mci_mismatch_node(struct scatterlist *sg, int node)
+{
+	// we use XOR to check weather mem addr matches the node id
+	return ((sg_phys(sg) >> 39) ^ node);
+}
+
+static u64 dw_mci_get_sg_mem_addr(struct dw_mci *host, struct mmc_data *data, int i, int node)
+{
+	struct mmc_dma_statistic *dma_statistic = &host->dma_statistic[node];
+	unsigned int length = sg_dma_len(&data->sg[i]);
+	u64 mem_addr = sg_dma_address(&data->sg[i]);
+	void *new_mem_vaddr;
+
+	if (data->flags & MMC_DATA_WRITE)
+		dma_statistic->write_cnt += 1;
+	else
+		dma_statistic->read_cnt += 1;
+
+	if (dw_mci_mismatch_node(&data->sg[i], node)) {
+		new_mem_vaddr = alloc_sg_mem_node(host, &data->sg[i], node);
+		if (data->flags & MMC_DATA_WRITE) {
+			dma_statistic->write_memcpy_cnt += 1;
+			memcpy(new_mem_vaddr, sg_virt(&data->sg[i]), length);
+		} else {	/* if MMC_DATA_READ */
+			struct cross_node_map_info *map_info = select_map_node(host);
+			map_info->source_vaddr = new_mem_vaddr;
+			map_info->dest_vaddr = (void *)sg_virt(&data->sg[i]);
+			map_info->length = length;
+			list_add_tail(&map_info->list_node, &host->cross_queue);
+			dma_statistic->read_memcpy_cnt += 1;
+		}
+		mem_addr = phys_to_dma(host->dev, virt_to_phys(new_mem_vaddr));
+	}
+
+	return mem_addr;
