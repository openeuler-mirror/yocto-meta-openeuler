+int mmc_get_cpu_node_num(void)
+{
+	static int chip_num = -1;
+	u32 online_cpus, node_id, i;
+
+	if (chip_num != -1)
+		return chip_num;
+
+	chip_num = 0;
+	online_cpus = num_online_cpus();
+	for (i = 0; i < online_cpus; ++i) {
+		node_id = (u32)cpu_to_node(i);
+		chip_num = node_id > chip_num ? node_id : chip_num;
+	}
+	chip_num += 1;
+	return chip_num;
+}
+EXPORT_SYMBOL(mmc_get_cpu_node_num);
