+#ifdef CONFIG_ASCEND_RAS_FEATURES
+static bool hugetlb_pfn_isolated(struct page *p)
+{
+	struct address_space *mapping;
+	struct page *head;
+	int count;
+
+	mapping = page_mapping(p);
+	head = compound_head(p);
+
+	if (!PageHWPoison(head))
+		return false;
+
+	count = page_count(head);
+	if (mapping) {
+		if (count == 2)
+			return true;
+	} else {
+		if (count == 0 || count == 1)
+			return true;
+	}
+
+	return false;
+}
+bool pfn_hwpoison_isolated(unsigned long pfn)
+{
+	struct address_space *mapping;
+	struct page *p, *head;
+	int count;
+
+	p = pfn_to_online_page(pfn);
+	if (!p)
+		return false;
+
+	if (PageHuge(p))
+		return hugetlb_pfn_isolated(p);
+
+	mapping = page_mapping(p);
+	head = compound_head(p);
+	count = page_count(head);
+
+	if (!PageHWPoison(p))
+		return false;
+
+	/* for shmem page cache */
+	if (mapping && shmem_mapping(mapping) && count == 2)
+		return true;
+
+	if (count == 0 || count == 1)
+		return true;
+
+	return false;
+}
+EXPORT_SYMBOL_GPL(pfn_hwpoison_isolated);
