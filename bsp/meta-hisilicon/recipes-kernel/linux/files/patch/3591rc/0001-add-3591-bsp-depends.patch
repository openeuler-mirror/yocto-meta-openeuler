+static void hisi_parse_card_detection_from_dt(struct dw_mci *host,
+						struct dw_mci_board *pdata)
+{
+	const struct dw_mci_drv_data *drv_data = host->drv_data;
+	struct device *dev = host->dev;
+
+	if (!mmc_is_ascend_customized(dev))
+		return;
+
+	if (device_property_present(dev, "non-removable"))
+		pdata->caps |= MMC_CAP_NONREMOVABLE;
+
+	if (device_property_present(dev, "keep-power-in-suspend"))
+		pdata->pm_caps |= MMC_PM_KEEP_POWER;
+
+	if (device_property_present(dev, "keep-power-ignore-pm-notify"))
+		pdata->pm_caps |= MMC_PM_IGNORE_PM_NOTIFY;
+
+	if (device_property_present(dev, "enable-sdio-wakeup"))
+		pdata->pm_caps |= MMC_PM_WAKE_SDIO_IRQ;
+
+	if (device_property_present(dev, "caps2-mmc-packed-command"))
+		pdata->caps2 |= MMC_CAP2_PACKED_CMD;
+
+	if (device_property_present(dev, "caps2-mmc-hs200-1_8v"))
+		pdata->caps2 |= MMC_CAP2_HS200_1_8V_SDR;
+
+	if (device_property_present(dev, "caps2-mmc-hs200-1_2v"))
+		pdata->caps2 |= MMC_CAP2_HS200_1_2V_SDR;
+
+	if (device_property_present(dev, "caps2-mmc-cache-ctrl")) {
+		dev_info(dev, "caps2-mmc-cache-ctrl is set in dts.\n");
+		dev_info(dev, "normal mode cache ctrl on\n");
+		pdata->caps2 |= MMC_CAP2_CACHE_CTRL;
+	}
+
+	if (device_property_present(dev, "caps2-wifi-support-cmd11")) {
