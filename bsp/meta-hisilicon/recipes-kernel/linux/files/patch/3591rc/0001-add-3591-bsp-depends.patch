diff --git a/drivers/mmc/host/mmc_misc_1910b.c b/drivers/mmc/host/mmc_misc_1910b.c
new file mode 100644
index 000000000..5ee9ef72d
--- /dev/null
+++ b/drivers/mmc/host/mmc_misc_1910b.c
@@ -0,0 +1,405 @@
+/*
+ * Copyright (c) Huawei Technologies Co., Ltd. 2022-2022. All rights reserved.
+ * Description: 自研emmc/sd misc源文件, 1911侧主要实现时钟 复位 等杂散功能
+ * Author: l00359800
+ * Create: 2022/08/13
+ */
+#include <linux/delay.h>
+#include <linux/of.h>
+#include <linux/bitfield.h>
+#include <linux/of_address.h>
+#include <linux/platform_device.h>
+#include <linux/mmc/host.h>
+#include "sdhci-pltfm.h"
+#include "sdhci_zodiac_mmc.h"
+
+/* PREI SUBCTRL reg */
+#define SC_EMMC_PHY_RESET_REQ_REG 0xA60 /* EMMC PHY软复位请求控制寄存器 */
+#define SRST_REQ_EMMC_PHY_TX (0x1 << 1)
+#define SRST_REQ_EMMC_PHY_RX (0x1 << 0)
+#define SC_EMMC_PHY_RESET_DREQ_REG 0xA64 /* EMMC PHY软复位去请求控制寄存器 */
+#define SRST_DREQ_EMMC_PHY_APB (0x1 << 2)
+#define SRST_DREQ_EMMC_PHY_TX (0x1 << 1)
+#define SRST_DREQ_EMMC_PHY_RX (0x1 << 0)
+#define SC_EMMC_PHY_RESET_ST_REG 0x5A60 /* EMMC PHY软复位状态寄存器 */
+#define SRST_ST_EMMC_PHY_TX (0x1 << 1)
+#define SRST_ST_EMMC_PHY_RX (0x1 << 0)
+#define SC_SD_RESET_REQ_REG 0xA68 /* SD 软复位请求控制寄存器 */
+#define SRST_REQ_SD (0x1 << 1)
+#define SRST_REQ_SD_APB (0x1 << 0)
+#define SC_SD_RESET_DREQ_REG 0xA6c /* SD 软复位去请求控制寄存器 */
+#define SRST_DREQ_SD (0x1 << 1)
+#define SRST_DREQ_SD_APB (0x1 << 0)
+#define SC_SD_RESET_ST_REG 0x5A68 /* SD软复位状态寄存器 */
+#define SRST_ST_SD  (0x1 << 1)
+#define SRST_ST_SD_APB (0x1 << 0)
+#define SC_EMMC_RESET_REQ_REG 0xA58 /* EMMC 软复位请求控制寄存器 */
+#define SRST_REQ_EMMC (0x1 << 1)
+#define SRST_REQ_EMMC_APB (0x1 << 0)
+#define SC_EMMC_RESET_DREQ_REG 0xA5C /* EMMC 软复位去请求控制寄存器 */
+#define SRST_DREQ_EMMC (0x1 << 1)
+#define SRST_DREQ_EMMC_APB (0x1 << 0)
+#define SC_EMMC_RESET_ST_REG 0x5A58 /* EMMC软复位状态寄存器 */
+#define SRST_ST_EMMC  (0x1 << 1)
+#define SRST_ST_EMMC_APB (0x1 << 0)
+
+#define SC_EMMC_ICG_EN_REG 0x360 /* EMMC时钟使能控制寄存器 */
+#define ICG_EN_EMMC (0x1 << 1)
+#define ICG_EN_EMMC_APB (0x1 << 0)
+#define SC_EMMC_ICG_DIS_REG 0x364 /* EMMC时钟去使能控制寄存器 */
+#define ICG_DIS_EMMC (0x1 << 1)
+#define ICG_DIS_EMMC_APB (0x1 << 0)
+#define SC_EMMC_ICG_ST_REG 0x5360 /* EMMC时钟状态寄存器 */
+#define ICG_ST_EMMC (0x1 << 1)
+#define ICG_ST_EMMC_APB (0x1 << 0)
+#define SC_EMMC_PHY_ICG_EN_REG 0x368 /* EMMC PHY时钟使能控制寄存器 */
+#define ICG_EN_EMMC_PHY_APB (0x1 << 0)
+#define SC_EMMC_PHY_ICG_DIS_REG 0x36C /* EMMC PHY时钟去使能控制寄存器 */
+#define ICG_DIS_EMMC_PHY_APB (0x1 << 0)
+#define SC_EMMC_PHY_ICG_ST_REG 0x5368 /* EMMC PHY时钟状态寄存器 */
+#define ICG_ST_EMMC_PHY_APB (0x1 << 0)
+#define SC_SD_ICG_EN_REG 0x370  /* SD时钟使能控制寄存器 */
+#define ICG_EN_SD (0x1 << 1)
+#define ICG_EN_SD_APB (0x1 << 0)
+#define SC_SD_ICG_DIS_REG 0x374 /* SD时钟去使能控制寄存器 */
+#define ICG_DIS_SD (0x1 << 1)
+#define ICG_DIS_SD_APB (0x1 << 0)
+#define SC_SD_ICG_ST_REG 0x5370 /* SD时钟状态寄存器 */
+#define ICG_ST_SD (0x1 << 1)
+#define ICG_ST_SD_APB (0x1 << 0)
+
+#define SC_SD_CLK_CFG_REG 0x160
+#define SD_CLK_DIV_CFG  GENMASK(4, 1)
+#define SD_CLK_SEL BIT(0)
+#define SC_EMMC_CLK_CFG_REG 0x164
+#define EMMC_CLK_DIV_CFG  GENMASK(4, 1)
+#define EMMC_CLK_SEL BIT(0)
+#define SC_SAMPLE_CCLK_SEL_REG 0x2400
+#define EMMC_CLK_SEL_FIXED_CLK (0x0 << 0)
+#define EMMC_CLK_SEL_TUNED_CLK (0x1 << 0)
+
+#define EMMC_POWER_EN_CTRL 0x2204
+#define PAD_EMMC_POWER_EN_OUT BIT(0)
+#define PAD_SDIO_CARD_POWER_EN_OUT BIT(1)
+
+#define SC_SWITCH_S12V100_REG 0x150
+#define SW_SEL     BIT(2)
+#define SW_RST_IN  BIT(1)
+#define SW_EN      BIT(0)
+#define SC_SDIO_MS 0x3500
+#define SDIO_PAD_3V3 0x0
+#define SDIO_PAD_1V8 0x2
+#define PADMG003   0x80c
+
+enum {
+    MMC_0,
+    MMC_MAX_NUM
+};
+static void __iomem *g_emmc_subctrl_vbase[MMC_MAX_NUM] = {0};
+static void __iomem *g_sd_subctrl_vbase[MMC_MAX_NUM] = {0};
+
+#define PERI_SUB_CTRL_BASE 0x80130000
+#define SUB_CTRL_SIZE  0x10000
+int hisi_mmc_subctrl_init(u32 host_mode, u32 host_id, struct device *dev)
+{
+    int subctrl_id;
+
+    if (host_id > MMC_MAX_NUM) {
+        return -EINVAL;
+    }
+
+    if (host_mode == 0) {
+        g_emmc_subctrl_vbase[host_id] = devm_ioremap(dev, PERI_SUB_CTRL_BASE, SUB_CTRL_SIZE);
+        if (!g_emmc_subctrl_vbase[host_id]) {
+            dev_err(dev, "subctrl_id = %d devm_ioremap failed\n", subctrl_id);
+            g_emmc_subctrl_vbase[host_id] = NULL;
+            return -ENOMEM;
+        }
+    } else {
+        g_sd_subctrl_vbase[host_id] = devm_ioremap(dev, PERI_SUB_CTRL_BASE, SUB_CTRL_SIZE);
+        if (!g_sd_subctrl_vbase[host_id]) {
+            dev_err(dev, "subctrl_id = %d devm_ioremap failed\n", subctrl_id);
+            g_sd_subctrl_vbase[host_id] = NULL;
+            return -ENOMEM;
+        }
+    }
+    return 0;
+}
+
+static inline void sdhci_sctrl_writel(void __iomem * vbase, u32 val, u32 reg)
+{
+    writel(val, vbase + reg);
+}
+
+static inline u32 sdhci_sctrl_readl(void __iomem * vbase, u32 reg)
+{
+    u32 ret;
+    ret = readl(vbase + reg);
+    return ret;
+}
+
+int hisi_subctrl_emmc_clkgate_enable(struct device *mmc_dev, u32 host_id)
+{
+    sdhci_sctrl_writel(g_emmc_subctrl_vbase[host_id], ICG_EN_EMMC | ICG_EN_EMMC_APB, SC_EMMC_ICG_EN_REG);
+    return 0;
+}
+
+int hisi_subctrl_sd_clkgate_enable(struct device *mmc_dev, u32 host_id)
+{
+    sdhci_sctrl_writel(g_sd_subctrl_vbase[host_id], ICG_EN_SD | ICG_EN_SD_APB, SC_SD_ICG_EN_REG);
+    return 0;
+}
+
+int hisi_subctrl_emmc_clkgate_disable(struct device *mmc_dev, u32 host_id)
+{
+    sdhci_sctrl_writel(g_emmc_subctrl_vbase[host_id], ICG_DIS_EMMC, SC_EMMC_ICG_DIS_REG);
+    return 0;
+}
+int hisi_subctrl_sd_clkgate_disable(struct device *mmc_dev, u32 host_id)
+{
+    sdhci_sctrl_writel(g_sd_subctrl_vbase[host_id], ICG_DIS_SD, SC_SD_ICG_DIS_REG);
+    return 0;
+}
+
+bool hisi_subctrl_emmc_clkgate_is_enabled(struct device *mmc_dev, u32 host_id)
+{
+    u32 val;
+    u32 mask;
+
+    val = sdhci_sctrl_readl(g_emmc_subctrl_vbase[host_id], SC_EMMC_ICG_ST_REG);
+    mask = ICG_ST_EMMC | ICG_ST_EMMC_APB;
+    return (((val & mask) == mask) ? true : false);
+}
+
+bool hisi_subctrl_sd_clkgate_is_enabled(struct device *mmc_dev, u32 host_id)
+{
+    u32 val;
+    u32 mask;
+
+    val = sdhci_sctrl_readl(g_sd_subctrl_vbase[host_id], SC_SD_ICG_ST_REG);
+    mask = ICG_ST_SD | ICG_ST_SD_APB;
+    return (((val & mask) == mask) ? true : false);
+}
+
+int hisi_subctrl_emmc_reset_assert(struct device *mmc_dev, u32 host_id)
+{
+    sdhci_sctrl_writel(g_emmc_subctrl_vbase[host_id], SRST_REQ_EMMC, SC_EMMC_RESET_REQ_REG);
+    return 0;
+}
+
+int hisi_subctrl_sd_reset_assert(struct device *mmc_dev, u32 host_id)
+{
+    /* sd reset */
+    sdhci_sctrl_writel(g_sd_subctrl_vbase[host_id], (SRST_REQ_SD | SRST_REQ_SD_APB), SC_SD_RESET_REQ_REG);
+    return 0;
+}
+
+int hisi_subctrl_emmc_reset_deassert(struct device *mmc_dev, u32 host_id)
+{
+    sdhci_sctrl_writel(g_emmc_subctrl_vbase[host_id], (SRST_DREQ_EMMC | SRST_DREQ_EMMC_APB), SC_EMMC_RESET_DREQ_REG);
+    return 0;
+}
+
+int hisi_subctrl_sd_reset_deassert(struct device *mmc_dev, u32 host_id)
+{
+    /* sd disreset */
+    sdhci_sctrl_writel(g_sd_subctrl_vbase[host_id], (SRST_DREQ_SD | SRST_DREQ_SD_APB), SC_SD_RESET_DREQ_REG);
+    return 0;
+}
+int hisi_subctrl_emmc_get_reset_status(struct device *mmc_dev, u32 host_id)
+{
+    u32 val;
+    u32 mask;
+
+    val = sdhci_sctrl_readl(g_emmc_subctrl_vbase[host_id], SC_EMMC_RESET_ST_REG);
+    mask = SRST_ST_EMMC | SRST_ST_EMMC_APB;
+    return ((val & mask) ? 1 : 0);
+}
+
+int hisi_subctrl_sd_get_reset_status(struct device *mmc_dev, u32 host_id)
+{
+    u32 val;
+    u32 mask;
+
+    val = sdhci_sctrl_readl(g_sd_subctrl_vbase[host_id], SC_SD_RESET_ST_REG);
+    mask = SRST_ST_SD | SRST_ST_SD_APB;
+    return ((val & mask) ? 1 : 0);
+}
+int hisi_subctrl_emmc_phy_clkgate_enable(struct device *mmc_dev, u32 host_id)
+{
+    sdhci_sctrl_writel(g_emmc_subctrl_vbase[host_id], ICG_EN_EMMC_PHY_APB, SC_EMMC_PHY_ICG_EN_REG);
+    return 0;
+}
+
+int hisi_subctrl_emmc_phy_clkgate_disable(struct device *mmc_dev, u32 host_id)
+{
+    sdhci_sctrl_writel(g_emmc_subctrl_vbase[host_id], ICG_DIS_EMMC_PHY_APB, SC_EMMC_PHY_ICG_DIS_REG);
+    return 0;
+}
+
+bool hisi_subctrl_emmc_phy_clkgate_is_enabled(struct device *mmc_dev, u32 host_id)
+{
+    u32 val;
+    u32 mask;
+
+    val = sdhci_sctrl_readl(g_emmc_subctrl_vbase[host_id], SC_EMMC_PHY_ICG_ST_REG);
+    mask = ICG_ST_EMMC_PHY_APB;
+    return ((val & mask) ? true : false);
+}
+
+int hisi_subctrl_emmc_phy_reset_assert(struct device *mmc_dev, u32 host_id)
+{
+    /* phy reset */
+    sdhci_sctrl_writel(g_emmc_subctrl_vbase[host_id], SRST_REQ_EMMC_PHY_TX | SRST_REQ_EMMC_PHY_RX,
+        SC_EMMC_PHY_RESET_REQ_REG);
+    return 0;
+}
+
+int hisi_subctrl_emmc_phy_reset_deassert(struct device *mmc_dev, u32 host_id)
+{
+    /* phy disreset */
+    sdhci_sctrl_writel(g_emmc_subctrl_vbase[host_id],
+        SRST_DREQ_EMMC_PHY_APB | SRST_DREQ_EMMC_PHY_TX | SRST_DREQ_EMMC_PHY_RX, SC_EMMC_PHY_RESET_DREQ_REG);
+    return 0;
+}
+
+int hisi_subctrl_emmc_phy_get_reset_status(struct device *mmc_dev, u32 host_id)
+{
+    u32 val;
+    u32 mask;
+
+    val = sdhci_sctrl_readl(g_emmc_subctrl_vbase[host_id], SC_EMMC_PHY_RESET_ST_REG);
+    mask = SRST_ST_EMMC_PHY_TX | SRST_ST_EMMC_PHY_RX;
+    return ((val & mask) ? 1 : 0);
+}
+
+int hisi_subctrl_emmc_set_clk_cfg(struct device *mmc_dev, u32 host_id, u32 sel, u32 div)
+{
+    u32 val;
+
+    val = sdhci_sctrl_readl(g_emmc_subctrl_vbase[host_id], SC_EMMC_CLK_CFG_REG);
+    val &= ~EMMC_CLK_DIV_CFG;
+    val |= FIELD_PREP(EMMC_CLK_DIV_CFG, div);
+    if (sel == 0) { // 低频晶振
+        val &= ~EMMC_CLK_SEL;
+    } else { // 高频时钟
+        val |= EMMC_CLK_SEL;
+    }
+    sdhci_sctrl_writel(g_emmc_subctrl_vbase[host_id], val, SC_EMMC_CLK_CFG_REG);
+    return 0;
+}
+
+int hisi_subctrl_sd_set_clk_cfg(struct device *mmc_dev, u32 host_id, u32 sel, u32 div)
+{
+    u32 val;
+
+    val = sdhci_sctrl_readl(g_sd_subctrl_vbase[host_id], SC_SD_CLK_CFG_REG);
+    val &= ~SD_CLK_DIV_CFG;
+    val |= FIELD_PREP(SD_CLK_DIV_CFG, div);
+    if (sel == 0) { // 低频晶振
+        val &= ~SD_CLK_SEL;
+    } else { // 高频时钟
+        val |= SD_CLK_SEL;
+    }
+    sdhci_sctrl_writel(g_sd_subctrl_vbase[host_id], val, SC_SD_CLK_CFG_REG);
+    return 0;
+}
+
+int hisi_subctrl_emmc_set_sample_clk(struct device *mmc_dev, u32 host_id, u32 sel)
+{
+    if (sel == 0) { // fixed时钟
+        sdhci_sctrl_writel(g_emmc_subctrl_vbase[host_id], EMMC_CLK_SEL_FIXED_CLK, SC_SAMPLE_CCLK_SEL_REG);
+    } else {  // tuned 时钟
+        sdhci_sctrl_writel(g_emmc_subctrl_vbase[host_id], EMMC_CLK_SEL_TUNED_CLK, SC_SAMPLE_CCLK_SEL_REG);
+    }
+    return 0;
+}
+
+#define PERI_IOMUX_BASE 0x82320000
+#define PERI_IOMUX_SIZE 0x10000
+#define PERI_IOMG000 0x0
+#define PAD_EMMC_POWER_EN 0x0
+#define PAD_GPIO2_09 0x3
+#define TEMP_DEBUG_POWER_EN 1
+int hisi_subctrl_emmc_set_power_en(struct device *mmc_dev, u32 host_id, u32 en)
+{
+    u32 reg_val;
+    void __iomem *peri_iomux_vbase;
+
+    peri_iomux_vbase = ioremap(PERI_IOMUX_BASE, PERI_IOMUX_SIZE);
+    if (!peri_iomux_vbase) {
+        pr_err("ioremap failed\n");
+        return -ENODEV;
+    }
+
+    reg_val = sdhci_sctrl_readl(g_emmc_subctrl_vbase[host_id], EMMC_POWER_EN_CTRL);
+    if (en == 1) {
+        //  配置复用为gpio2_9 利用gpio弱上拉上电,规避休眠唤醒上电挂死问题
+        writel(PAD_GPIO2_09, peri_iomux_vbase + PERI_IOMG000);
+        udelay(100); // 延时100us
+        reg_val |= PAD_EMMC_POWER_EN_OUT;
+    } else {
+        reg_val &= ~PAD_EMMC_POWER_EN_OUT;
+    }
+    // power en输出高或者低
+    sdhci_sctrl_writel(g_emmc_subctrl_vbase[host_id], reg_val, EMMC_POWER_EN_CTRL);
+    //  配置复用为emmc_power_en功能
+    writel(PAD_EMMC_POWER_EN, peri_iomux_vbase + PERI_IOMG000);
+    iounmap(peri_iomux_vbase);
+    return 0;
+}
+
+int hisi_subctrl_sd_set_power_en(struct device *mmc_dev, u32 host_id, u32 en)
+{
+    u32 reg_val;
+
+    reg_val = sdhci_sctrl_readl(g_sd_subctrl_vbase[host_id], EMMC_POWER_EN_CTRL);
+    if (en == 1) {
+        reg_val |= PAD_SDIO_CARD_POWER_EN_OUT; // 接芯片管脚SDIO_CARD_POWER_EN, SDIO电源使能控制信号，高有效。
+    } else {
+        reg_val &= ~PAD_SDIO_CARD_POWER_EN_OUT;
+    }
+    sdhci_sctrl_writel(g_sd_subctrl_vbase[host_id], reg_val, EMMC_POWER_EN_CTRL);
+    return 0;
+}
+
+int hisi_subctrl_sd_volt_switch_1v8(struct device *mmc_dev, u32 host_id, u32 set)
+{
+    void __iomem *peri_iomux_vbase;
+    u32 val;
+
+    val = sdhci_sctrl_readl(g_sd_subctrl_vbase[host_id], SC_SWITCH_S12V100_REG);
+    val |= SW_RST_IN;
+    sdhci_sctrl_writel(g_sd_subctrl_vbase[host_id], val, SC_SWITCH_S12V100_REG);
+    val |= SW_EN;
+    sdhci_sctrl_writel(g_sd_subctrl_vbase[host_id], val, SC_SWITCH_S12V100_REG);
+
+    peri_iomux_vbase = ioremap(PERI_IOMUX_BASE, PERI_IOMUX_SIZE);
+    if (!peri_iomux_vbase) {
+        pr_err("devm_ioremap failed\n");
+        return -ENODEV;
+    }
+    if (set == 1) {
+        pr_err("switch to 1v8 ,config PADMG003\n");
+        writel(0x00000060, peri_iomux_vbase + PADMG003); // 切1v8失败板级规避方案
+        val |= SW_SEL; // AVDD18
+    } else {
+        pr_err("switch to 3V3 ,config PADMG003\n");
+        writel(0x00010071, peri_iomux_vbase + PADMG003);
+        val &= ~SW_SEL; // AVDD33
+    }
+    iounmap(peri_iomux_vbase);
+    sdhci_sctrl_writel(g_sd_subctrl_vbase[host_id], val, SC_SWITCH_S12V100_REG);
+    mdelay(10); // 延时10ms
+    if (set == 1) {
+        sdhci_sctrl_writel(g_sd_subctrl_vbase[host_id], SDIO_PAD_1V8, SC_SDIO_MS);
+    } else {
+        sdhci_sctrl_writel(g_sd_subctrl_vbase[host_id], SDIO_PAD_3V3, SC_SDIO_MS);
+    }
+    return 0;
+}
