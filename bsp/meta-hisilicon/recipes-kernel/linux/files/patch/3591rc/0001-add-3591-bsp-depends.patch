+#ifdef CONFIG_EULEROS_KBOX_SMP_IPI_CALLBACK
+/* taking into account other cpu architecture does not necessarily
+ * have such similar NMI mechanism, or to achieve different,
+ * so put the code under the arch directory
+ */
+
+#define SMP_NMI_CALL_FUNC_NAME "smp_nmi_call"
+#define UDELAY_100US			(100)
+static DECLARE_BITMAP(smp_call_mask, NR_CPUS) __read_mostly;
+static DECLARE_BITMAP(cpu_mask_before_nmi, NR_CPUS);
+static atomic_t calling_cpu = ATOMIC_INIT(-1);
+static atomic_t os_reg_nmi_flag = ATOMIC_INIT(0);
+
+typedef void (*smp_nmi_call_func_t)(unsigned long info, struct pt_regs *regs);
+
+struct smp_nmi_call_function_data {
+	smp_nmi_call_func_t func;
+	unsigned long info;    /* only 8 bytes information can be passed */
+};
+
+static struct smp_nmi_call_function_data smp_nmi_callback_data = {
+	.func = NULL,
+	.info = 0,
+};
+
+static int smp_nmi_call_function_handler(unsigned int val, struct pt_regs *regs)
+{
+	const int cpu = smp_processor_id();
+
+	if (cpumask_test_cpu(cpu, to_cpumask(smp_call_mask))) {
+		if (smp_nmi_callback_data.func) {
+			smp_nmi_callback_data.func(smp_nmi_callback_data.info, regs);
+		}
+
+		cpumask_clear_cpu(cpu, to_cpumask(smp_call_mask));
+		return NMI_HANDLED;
+	}
+
+	return NMI_DONE;
+}
+
+/*
+ * kbox_smp_nmi_call_function(): Run a function on all other CPUs.
+ * @func: The function to run. This must be fast and non-blocking.
+ * @info: An arbitrary pointer to pass to the function.
+ * @wait: If true, wait (atomically) until function has completed
+ *        on other CPUs.
+ * @time: timeout value if @wait is true.
+ * Returns 0.
+ *
+ * If @wait is true, then returns once @func has returned; otherwise
+ * it returns just before the target cpu calls @func.
+ *
+ * You must not call this function with disabled interrupts or from a
+ * hardware interrupt handler or from a bottom half handler.
+ */
+int kbox_smp_nmi_call_function(smp_nmi_call_func_t run_func, unsigned long data, int wait, long time)
+{
+	int ret = 0;
+	long timeout = 0;
+	int cur_cpu = -1;
+
+	/* protection, if the current system is being forced to reboot, then do not execute */
+	if (reboot_force) {
+		pr_emerg("smp_nmi_call_function:now, reboot -f is running!\n");
+		return -1;
+	}
+
+	/*
+	 * Use an own vector here because smp_call_function
+	 * does lots of things not suitable in a panic situation.
+	 */
+	if (num_online_cpus() <= 1) {
+		pr_emerg("smp_nmi_call_function:only one cpu is running!\n");
+		return 0;
+	}
+
+	/* record the current CPU, does not support concurrent */
+	cur_cpu = safe_smp_processor_id();
+	if (atomic_cmpxchg(&calling_cpu, -1, cur_cpu) != -1) {
+		/* Note that it does not modify calling_cpu */
+		pr_emerg("first calling cpu is %d. cur cpu is %d.\n", atomic_read(&calling_cpu), cur_cpu);
+		return -1;
+	}
+
+	smp_nmi_callback_data.func = run_func;
+	smp_nmi_callback_data.info = data;
+
+	cpumask_copy(to_cpumask(smp_call_mask), cpu_online_mask);
+	cpumask_clear_cpu(cur_cpu, to_cpumask(smp_call_mask));
+
+	cpumask_copy(to_cpumask(cpu_mask_before_nmi), to_cpumask(smp_call_mask));
+
+	pr_emerg("cpu %d will send nmi, the cpumask: 0x%lx\n", cur_cpu, *smp_call_mask);
+
+	/* register nmi handler Note that registered the highest priority */
+	if (0 == atomic_read(&os_reg_nmi_flag)) {
+		ret = register_nmi_handler(NMI_LOCAL, smp_nmi_call_function_handler, NMI_FLAG_FIRST, SMP_NMI_CALL_FUNC_NAME);
+		if (ret != 0) {
+			pr_emerg("smp_nmi_call_function register fail, ret = %d\n", ret);
+			goto out;
+		}
+		atomic_set(&os_reg_nmi_flag, 1);
+	}
+
+	/* sync above data before sending NMI */
+	wbinvd();
+	wmb();
+
+	/* Note that sending cpu does not perform callback */
+	apic->send_IPI_allbutself(NMI_VECTOR);
+
+	/* if asynchronous mode, without waiting, exit */
+	if (!wait) {
+		goto out;
+	}
+
+	/*
+	 * Don't wait longer than a second if the caller
+	 * didn't ask us to wait.
+	 */
+	timeout = ((time < 0) ? USEC_PER_SEC : min(USEC_PER_SEC, time));
+	while (timeout > 0) {
+		udelay(UDELAY_100US);
+		timeout -= UDELAY_100US;
+		/* for CPU no stop scenario, cpu will not offline */
+		if (cpumask_empty(to_cpumask(smp_call_mask))) {
+			break;
+		}
+
+		/* for CPU stop scenario, cpu mask will not be cleared */
+		if (num_online_cpus() <= 1) {
+			break;
+		}
+	}
+
+out:
+	pr_emerg("smp_nmi_call_function is finished. wait: %d, time: %ld, timeout: %ld, cpumask: 0x%lx\n",
+		wait, time, timeout, *smp_call_mask);
+
+	cpumask_clear(to_cpumask(cpu_mask_before_nmi));
+	cpumask_clear(to_cpumask(smp_call_mask));
+	udelay(10); /* wait for all other CPUs finish judging func pointer */
+	smp_nmi_callback_data.func = NULL;
+	smp_nmi_callback_data.info = 0;
+	atomic_set(&calling_cpu, -1);
+
+	return 0;
+}
+EXPORT_SYMBOL(kbox_smp_nmi_call_function);
+#endif
