+
+static void sdhci_zodiac_disable_clk(struct sdhci_host *host)
+{
+    u16 reg;
+    ktime_t timeout;
+    bool timedout;
+
+    reg = sdhci_readw(host, SDHCI_CLOCK_CONTROL);
+    reg &= ~SDHCI_CLOCK_CARD_EN;
+    sdhci_writew(host, reg, SDHCI_CLOCK_CONTROL);
+    reg &= ~SDHCI_CLOCK_INT_EN;
+    sdhci_writew(host, reg, SDHCI_CLOCK_CONTROL);
+
+    timeout = ktime_add_ms(ktime_get(), SDHCI_ZODIAC_CLK_STABLE_TIME);
+    while (1) {
+        timedout = ktime_after(ktime_get(), timeout);
+        reg = sdhci_readw(host, SDHCI_CLOCK_CONTROL);
+        if (!(reg & SDHCI_CLOCK_INT_STABLE))
+            break;
+        if (timedout) {
+            pr_err("%s: Internal clock never stabilised.\n", mmc_hostname(host->mmc));
+            sdhci_dumpregs(host);
+            return;
+        }
+        udelay(10); // 延时10us
+    }
+}
+
+static void sdhci_zodiac_enable_clk(struct sdhci_host *host)
+{
+    u16 reg;
+    ktime_t timeout;
+    bool timedout;
+
+    reg = sdhci_readw(host, SDHCI_CLOCK_CONTROL);
+    reg |= SDHCI_CLOCK_INT_EN;
+    sdhci_writew(host, reg, SDHCI_CLOCK_CONTROL);
+
+    timeout = ktime_add_ms(ktime_get(), SDHCI_ZODIAC_CLK_STABLE_TIME);
+    while (1) {
+        timedout = ktime_after(ktime_get(), timeout);
+        reg = sdhci_readw(host, SDHCI_CLOCK_CONTROL);
+        if (reg & SDHCI_CLOCK_INT_STABLE)
+            break;
+        if (timedout) {
+            pr_err("%s: Internal clock never stabilised.\n", mmc_hostname(host->mmc));
+            sdhci_dumpregs(host);
+            return;
+        }
+        udelay(10); // 延时10us
+    }
+
+    reg |= SDHCI_CLOCK_CARD_EN;
+    sdhci_writew(host, reg, SDHCI_CLOCK_CONTROL);
+}
+
+static void sdhci_zodiac_set_clk_sel(struct sdhci_host *host, u8 timing)
+{
+    struct sdhci_pltfm_host *pltfm_host = sdhci_priv(host);
+    struct sdhci_zodiac_host *zodiac_host = sdhci_pltfm_priv(pltfm_host);
+
+    if (zodiac_host->host_mode == ZODIAC_EMMC_MODE) {
+        if (timing == MMC_TIMING_LEGACY) { // 初始化枚举时 使用4M低频晶振 不分频
+            (void)hisi_subctrl_emmc_set_clk_cfg(zodiac_host->dev, zodiac_host->host_id, L_CLK, 0);
+        } else {
+            (void)hisi_subctrl_emmc_set_clk_cfg(zodiac_host->dev, zodiac_host->host_id, H_CLK, 0);
+        }
+
+        if (timing == MMC_TIMING_MMC_HS400 || timing == MMC_TIMING_MMC_HS200) {
+            // hs200和hs400选择sample时钟为phy时钟 而非固定时钟
+            (void)hisi_subctrl_emmc_set_sample_clk(zodiac_host->dev, zodiac_host->host_id, TUNED_CLK);
+        } else {
+            (void)hisi_subctrl_emmc_set_sample_clk(zodiac_host->dev, zodiac_host->host_id, FIXED_CLK);
+        }
+    } else {
+        if (timing == MMC_TIMING_LEGACY) { // 初始化枚举时 使用4M低频晶振 不分频
+            (void)hisi_subctrl_sd_set_clk_cfg(zodiac_host->dev, zodiac_host->host_id, L_CLK, 0);
+        } else {
+            (void)hisi_subctrl_sd_set_clk_cfg(zodiac_host->dev, zodiac_host->host_id, H_CLK, 0);
+        }
+    }
+}
+
+static void sdhci_zodiac_timing_cfg(struct sdhci_host *host, u8 timing)
+{
+    struct sdhci_pltfm_host *pltfm_host = sdhci_priv(host);
+    struct sdhci_zodiac_host *zodiac_host = sdhci_pltfm_priv(pltfm_host);
+    u32 val;
+    struct sdhci_clk_cfg *crg;
+    struct sdhci_timing_cfg *timing_cfg;
+
+    crg = &zodiac_host->clk_cfg[timing];
+    timing_cfg = &crg->timing_cfg;
+    // 配置同步/异步模式 时序参数
+    val = sdhci_readl(host, SDEMMC_TIMING_CTRL_0);
+    val &= ~(CFG_READ_WAIT_START | CFG_READ_AUTO_CMD12_START | CFG_CMD_TIMEOUT_CNT | CFG_CMD_RESP_CNT);
+    if (zodiac_host->host_mode == ZODIAC_EMMC_MODE) { // EMMC控制器 0x90寄存器bit31位oe_mask_en, sd控制器该bit是保留位
+        val &= ~OE_MASK_EN;
+        if (timing_cfg->oe_mask_en == 1) {
+            val |= OE_MASK_EN;
+        }
+    }
+    val |= FIELD_PREP(CFG_READ_WAIT_START, timing_cfg->read_wait_start);
+    val |= FIELD_PREP(CFG_READ_AUTO_CMD12_START, timing_cfg->read_auto_cmd12_start);
+    val |= FIELD_PREP(CFG_CMD_TIMEOUT_CNT, timing_cfg->cmd_timeout_cnt);
+    val |= FIELD_PREP(CFG_CMD_RESP_CNT, timing_cfg->cmd_resp_cnt);
+    sdhci_writel(host, val, SDEMMC_TIMING_CTRL_0);
+
+    val = sdhci_readl(host, SDEMMC_TIMING_CTRL_1);
+    val &= ~(CRC_ST_DET_DLY_MODE | CRC_ST_DET_DLY | CRC_ST_CHK_DLY);
+    if (timing_cfg->crc_st_det_dly_mode == 1) {
+        val |= CRC_ST_DET_DLY_MODE;
+    }
+    val |= FIELD_PREP(CRC_ST_DET_DLY, timing_cfg->crc_st_det_dly);
+    val |= FIELD_PREP(CRC_ST_CHK_DLY, timing_cfg->crc_st_chk_dly);
+    sdhci_writel(host, val, SDEMMC_TIMING_CTRL_1);
+
+    val = sdhci_readl(host, SDEMMC_TIMING_CTRL_2);
+    val &= ~(CFG_STOP_SDCLK_RD_START);
+    val |= FIELD_PREP(CFG_STOP_SDCLK_RD_START, timing_cfg->stop_sdclk_rd_start);
+    sdhci_writel(host, val, SDEMMC_TIMING_CTRL_2);
+}
+
+static void sdhci_zodiac_set_crg_timing_para(struct sdhci_host *host, u8 timing)
+{
+    struct sdhci_pltfm_host *pltfm_host = sdhci_priv(host);
+    struct sdhci_zodiac_host *zodiac_host = sdhci_pltfm_priv(pltfm_host);
+    u32 val;
+    struct sdhci_clk_cfg *cfg;
+
+    cfg = &zodiac_host->clk_cfg[timing];
+    val = sdhci_readl(host, SDHCI_CRG_CTRL0);
+    val &= ~(SDEMMC_SAMP_SEL | SDEMMC_CLK_DIV | SDEMMC_CLK_DLY_DRV | SDEMMC_CLK_DLY_SAMPLE);
+    if (cfg->sample_mode == ASYNC_MODE) {
+        val |= SDEMMC_SAMP_SEL;
+    }
+    val |= FIELD_PREP(SDEMMC_CLK_DIV, cfg->clk_div); // 1911 emmc控制器配置0x80寄存器 分频无效 分频值固定填0xf
+    val |= FIELD_PREP(SDEMMC_CLK_DLY_DRV, cfg->clk_dly_drv);
+    val |= FIELD_PREP(SDEMMC_CLK_DLY_SAMPLE, cfg->clk_dly_sample);
+
+    sdhci_writel(host, val, SDHCI_CRG_CTRL0);
+    host->max_clk = cfg->max_clk;
+    // 配置同步模式 异步模式 时序参数 timing == MMC_TIMING_LEGACY
+    if (timing == MMC_TIMING_LEGACY || timing == MMC_TIMING_UHS_SDR50 || timing == MMC_TIMING_UHS_SDR104 ||
+        timing == MMC_TIMING_MMC_HS200 || timing == MMC_TIMING_MMC_HS400 || timing == MMC_TIMING_MMC_DDR52) {
+        sdhci_zodiac_timing_cfg(host, timing);
+    }
+}
+
+void sdhci_zoidac_set_card_power_en(struct sdhci_host *host, u32 en)
+{
+    struct sdhci_pltfm_host *pltfm_host = sdhci_priv(host);
+    struct sdhci_zodiac_host *zodiac_host = sdhci_pltfm_priv(pltfm_host);
+    if (zodiac_host->host_mode == ZODIAC_EMMC_MODE) {
+        (void)hisi_subctrl_emmc_set_power_en(zodiac_host->dev, zodiac_host->host_id, en);
+    } else {
+        (void)hisi_subctrl_sd_set_power_en(zodiac_host->dev, zodiac_host->host_id, en);
+    }
+}
+
+static int sdhci_zodiac_reset(struct sdhci_host *host)
+{
+    int ret;
+    // 1、 关时钟
+    sdhci_zodiac_icg_dis(host);
+    // 2、复位
+    sdhci_zodiac_hardware_reset(host);
+    // 3、开时钟
+    ret = sdhci_zodiac_icg_en(host);
+    if (ret != 0) {
+        return ret;
+    }
+    // 4、等待100us
+    udelay(100);
+    // 5、 关时钟
+    sdhci_zodiac_icg_dis(host);
+    // 6、解复位
+    ret = sdhci_zodiac_hardware_disreset(host);
+    if (ret != 0) {
+        return ret;
+    }
+    // 7、开时钟
+    ret = sdhci_zodiac_icg_en(host);
+    if (ret != 0) {
+        return ret;
+    }
+    return 0;
+}
+
+static int sdhci_zodiac_init_cfg(struct sdhci_host *host)
+{
+    struct sdhci_pltfm_host *pltfm_host = sdhci_priv(host);
+    struct sdhci_zodiac_host *zodiac_host = sdhci_pltfm_priv(pltfm_host);
+    int ret;
+
+    // 软复位控制器
+    ret = sdhci_zodiac_reset(host);
+    if (ret != 0) {
+        return ret;
+    }
+    // 给卡或者颗粒上电
+    sdhci_zoidac_set_card_power_en(host, 1);
+    // emmc 还需要初始化phy
+
+    if (zodiac_host->host_mode == ZODIAC_EMMC_MODE) {
+        return sdhci_combo_phy_init(host);
+    }
+    return 0;
+}
+
+static void sdhci_zodiac_select_clk_src(struct sdhci_host *host, struct mmc_ios *ios)
+{
+    int ret;
+
+    if (ios->timing > MMC_TIMING_MMC_HS400) {
+        pr_err("sdhci_zodiac_select_clk_src failed, timing %d exceed max\n", ios->timing);
+        return;
+    }
+
+    // 关时钟门控
+    sdhci_zodiac_icg_dis(host);
+    // 切时钟 初始化使用低频晶振  正常跑使用高频时钟
+    sdhci_zodiac_set_clk_sel(host, ios->timing);
+    // 开时钟门控
+    ret = sdhci_zodiac_icg_en(host);
+    if (ret != 0) {
+        return;
+    }
+    // 配置crg_ctrl寄存器和 timing相关寄存器
+    sdhci_zodiac_set_crg_timing_para(host, ios->timing);
+}
+
+static int sdhci_phy_delay_measurement(struct sdhci_host *host, struct mmc_ios *ios)
+{
+    int ret;
+    if ((host->clock == MMC_HS200_MAX_DTR || host->clock == MMC_HIGH_DDR_MAX_DTR || host->clock == host->mmc->f_max)) {
+        ret = sdhci_combo_phy_delay_measurement(host, ios);
+        if (ret != 0) {
+            pr_err("sdhci_combo_phy_delay_measurement fail!\n");
+            return ret;
+        }
+    }
+    return 0;
+}
+
+static void sdhci_zodiac_set_clock(struct sdhci_host *host, unsigned int clock)
+{
+    u16 clk;
+    struct sdhci_pltfm_host *pltfm_host = sdhci_priv(host);
+    struct sdhci_zodiac_host *zodiac_host = sdhci_pltfm_priv(pltfm_host);
+
+    host->mmc->actual_clock = 0;
+    //  关闭卡侧时钟
+    sdhci_zodiac_disable_clk(host);
+    if (clock == 0) {
+        return;
+    }
+    // 选择时钟源 高频 or 低频晶振
+    sdhci_zodiac_select_clk_src(host, &host->mmc->ios);
+    clk = sdhci_calc_clk(host, clock, &host->mmc->actual_clock);
+    // 开卡侧时钟并等稳定
+    sdhci_enable_clk(host, clk);
+
+    if (zodiac_host->host_mode == ZODIAC_EMMC_MODE) {
+        (void)sdhci_phy_delay_measurement(host, &host->mmc->ios);
+    }
+}
+
+static void sdhci_zodiac_hw_reset(struct sdhci_host *host)
+{
+    struct sdhci_pltfm_host *pltfm_host = sdhci_priv(host);
+    struct sdhci_zodiac_host *zodiac_host = sdhci_pltfm_priv(pltfm_host);
+    int ret;
+
+    sdhci_zodiac_hardware_reset(host);
+    ret = sdhci_zodiac_hardware_disreset(host);
+    if (ret != 0) {
+        dev_err(zodiac_host->dev, "sdhci_zodiac_hw_reset, sdhci_zodiac_hardware_disreset fail\n");
+        return;
+    }
+    if (zodiac_host->host_mode == ZODIAC_EMMC_MODE) {
+        (void)sdhci_combo_phy_init(host);
+    }
+}
+
+int sdhci_zodiac_enable_dma(struct sdhci_host *host)
+{
+    u8 val;
+
+    if (host->runtime_suspended) {
+        return 0;
+    }
+    val = sdhci_readb(host, SDHCI_HOST_CONTROL);
+    val &= ~SDHCI_CTRL_DMA_MASK;
+    if (host->flags & SDHCI_USE_ADMA) {
+        if (host->flags & SDHCI_USE_64_BIT_DMA) {
+            val |= SDHCI_CTRL_ADMA64;
+        } else {
+            val |= SDHCI_CTRL_ADMA32;
+        }
+    } else {
+        val |= SDHCI_CTRL_SDMA;
+    }
+    sdhci_writeb(host, val, SDHCI_HOST_CONTROL);
+    return 0;
+}
+
+static int sdhci_zodiac_execute_hwtuning(struct sdhci_host *host, u32 opcode)
+{
+    int i;
+    int err = -EIO;
+    u16 val;
+
+    for (i = 0; i < MAX_TUNING_LOOP; i++) {
+        sdhci_zodiac_disable_clk(host); // 硬件tuning相比原生的代码 多了开关时钟，自研控制器特有
+        sdhci_zodiac_enable_clk(host);
+        sdhci_send_tuning(host, opcode);
+
+        if (host->tuning_done == 0) {
+            pr_err("%s: Tuning timeout, falling back to fixed sampling clock\n", mmc_hostname(host->mmc));
+            sdhci_abort_tuning(host, opcode);
+            err = -ETIMEDOUT;
+            return err;
+        }
+        val = sdhci_readw(host, SDHCI_HOST_CONTROL2);
+        if ((val & SDHCI_CTRL_EXEC_TUNING) == 0) {
+            if (val & SDHCI_CTRL_TUNED_CLK) {
+                return 0; /* Success! */
+            }
+            err = -EAGAIN;
+            pr_err("%s: Tuning failed, falling back to fixed sampling clock\n", mmc_hostname(host->mmc));
+            sdhci_reset_tuning(host);
+            return err;
+        }
+
+        /* Spec does not require a delay between tuning cycles */
+        if (host->tuning_delay > 0) {
+            mdelay(host->tuning_delay);
+        }
+    }
+    return err;
+}
+
+static int sdhci_zodiac_platform_execute_tuning(struct sdhci_host *host, u32 opcode)
+{
+    int err;
+
+    if (host->tuning_delay < 0) {
+        host->tuning_delay = (opcode == MMC_SEND_TUNING_BLOCK) ? 1 : 0 ;
+    }
+
+    sdhci_start_tuning(host);
+    err = sdhci_zodiac_execute_hwtuning(host, opcode);
+    sdhci_end_tuning(host);
+    sdhci_zodiac_disable_clk(host); // 这里增加关开时钟操作 硬件控制器才能把硬tuning到的相位值设进去
+    sdhci_zodiac_enable_clk(host);
+
+    if (err != 0) {
+        sdhci_dumpregs(host);
+        pr_err("hw tuning fail! err = %d\r\n", err);
+        return err;
+    }
+    // 硬件tuning成功, 打印tuning得到的最佳相位点
+    pr_info("hw tuning success !  best_phase = %u\r\n", sdhci_readl(host, TUNING_RESULT_VALUE_REG));
+    return err;
+}
+
+static void sdhci_zodiac_power_off(struct sdhci_host *host)
+{
+    sdhci_writeb(host, 0, SDHCI_POWER_CONTROL);
+    // 给卡或者颗粒下电
+    sdhci_zoidac_set_card_power_en(host, 0);
+}
+
+static void sdhci_zodiac_sd_sel_1v8(struct sdhci_host *host, u32 set)
+{
+    struct sdhci_pltfm_host *pltfm_host = sdhci_priv(host);
+    struct sdhci_zodiac_host *zodiac_host = sdhci_pltfm_priv(pltfm_host);
+
+    hisi_subctrl_sd_volt_switch_1v8(zodiac_host->dev, zodiac_host->host_id, set);
+}
+
+static void sdhci_zodiac_power_up(struct sdhci_host *host)
+{
+    struct sdhci_pltfm_host *pltfm_host = sdhci_priv(host);
+    struct sdhci_zodiac_host *zodiac_host = sdhci_pltfm_priv(pltfm_host);
+
+    if (zodiac_host->host_mode == ZODIAC_SD_MODE) {
+        sdhci_zodiac_sd_sel_1v8(host, 0);     // sd控制器 初始3v3
+    } else if (zodiac_host->host_mode == ZODIAC_SDIO_MODE) {
+        sdhci_zodiac_sd_sel_1v8(host, 1); // sdio初始化为1v8
+    }
+
+    sdhci_writeb(host, SDHCI_POWER_ON, SDHCI_POWER_CONTROL);
+    // 给卡或者颗粒上电
+    sdhci_zoidac_set_card_power_en(host, 1);
+}
+
+static void sdhci_zodiac_set_power(struct sdhci_host *host, unsigned char mode, unsigned short vdd)
+{
+    struct sdhci_pltfm_host *pltfm_host = sdhci_priv(host);
+    struct sdhci_zodiac_host *zodiac_host = sdhci_pltfm_priv(pltfm_host);
+    struct device *dev = zodiac_host->dev;
+
+    if (zodiac_host->power_mode == mode) {
+        /* no need change power */
+        return;
+    }
+
+    switch (mode) {
+        case MMC_POWER_OFF:
+            dev_info(dev, "set io to lowpower\n");
+            sdhci_zodiac_power_off(host);
+            break;
+        case MMC_POWER_UP:
+            dev_info(dev, "set io to normal\n");
+            sdhci_zodiac_power_up(host);
+            break;
+        case MMC_POWER_ON:
+            break;
+        default:
+            dev_err(dev, "unknown power supply mode\n");
+            break;
+    }
+    zodiac_host->power_mode = mode;
+}
+
+static void sdhci_zodiac_voltage_switch(struct sdhci_host *host)
+{
+    struct sdhci_pltfm_host *pltfm_host = sdhci_priv(host);
+    struct sdhci_zodiac_host *zodiac_host = sdhci_pltfm_priv(pltfm_host);
+
+    // sd切成1v8
+    if (zodiac_host->host_mode == ZODIAC_SD_MODE) {
+        sdhci_zodiac_sd_sel_1v8(host, 1);
+    }
+}
+
+static unsigned int sdhci_zodiac_get_max_clock(struct sdhci_host *host)
+{
+    struct sdhci_pltfm_host *pltfm_host = sdhci_priv(host);
+    // sdhci_get_property中 解析clock-frequency得到pltfm_host->clock
+    return pltfm_host->clock;
+}
