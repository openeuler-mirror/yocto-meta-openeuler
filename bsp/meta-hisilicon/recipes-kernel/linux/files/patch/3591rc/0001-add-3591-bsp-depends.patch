+#define MASTER_SG_LIST_ADDR 0x2F341000
+#define SLAVE_SG_LIST_ADDR 0x802F341000
+
+static int dw_mci_sg_dma_map(struct dw_mci *host)
+{
+	host->sg_cpu = (void *)ioremap(MASTER_SG_LIST_ADDR,
+					HISI_DISC_DZ(host) * DESC_RING_BUF_SZ);
+	if (host->sg_cpu == NULL) {
+		dev_err(host->dev, "ioremap failed.\n");
+		return -ENOMEM;
+	}
+	host->sg_dma = dma_map_resource(host->dev, MASTER_SG_LIST_ADDR,
+				HISI_DISC_DZ(host) * DESC_RING_BUF_SZ, DMA_BIDIRECTIONAL, 0);
+	if (dma_mapping_error(host->dev, host->sg_dma)) {
+		dev_err(host->dev, "sg_dma mapping failed.\n");
+		goto dma_map_failed;
+	}
+
+	if (mmc_get_cpu_node_num() <= 1)
+		return 0;
+
+	host->sg_cpu2 = (void *)ioremap(SLAVE_SG_LIST_ADDR,
+					HISI_DISC_DZ(host) * DESC_RING_BUF_SZ);
+	if (host->sg_cpu2 == NULL) {
+		dev_err(host->dev, "ioremap failed.\n");
+		goto cpu2_map_failed;
+	}
+	host->sg_dma2 = dma_map_resource(host->dev, SLAVE_SG_LIST_ADDR,
+				HISI_DISC_DZ(host) * DESC_RING_BUF_SZ, DMA_BIDIRECTIONAL, 0);
+	if (dma_mapping_error(host->dev, host->sg_dma2)) {
+		dev_err(host->dev, "sg_dma2 mapping failed.\n");
+		goto dma2_map_failed;
+	}
+	return 0;
+dma2_map_failed:
+	iounmap(host->sg_cpu2);
+cpu2_map_failed:
+	dma_unmap_resource(host->dev, host->sg_dma,
+				HISI_DISC_DZ(host) * DESC_RING_BUF_SZ, DMA_BIDIRECTIONAL, 0);
+dma_map_failed:
+	iounmap(host->sg_cpu);
+	return -ENOMEM;
+}
+
+static void dw_mci_sg_dma_unmap(struct dw_mci *host)
+{
+	if (host->sg_cpu) {
+		iounmap(host->sg_cpu);
+		host->sg_cpu = NULL;
+	}
+	if (host->sg_dma) {
+		dma_unmap_resource(host->dev, host->sg_dma,
+			HISI_DISC_DZ(host) * DESC_RING_BUF_SZ, DMA_BIDIRECTIONAL, 0);
+		host->sg_dma = 0;
+	}
+	if (host->sg_cpu2) {
+		iounmap(host->sg_cpu2);
+		host->sg_cpu2 = NULL;
+	}
+	if (host->sg_dma2) {
+		dma_unmap_resource(host->dev, host->sg_dma2,
+			HISI_DISC_DZ(host) * DESC_RING_BUF_SZ, DMA_BIDIRECTIONAL, 0);
+		host->sg_dma2 = 0;
+	}
+}
