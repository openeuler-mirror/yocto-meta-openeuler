+#ifdef CONFIG_EULEROS_KBOX_SMP_IPI_CALLBACK
+static int smp_nmi_call_function(smp_nmi_call_func_t run_func, unsigned long data, int wait, long time)
+{
+	unsigned long timeout;
+	int cpu = -1;
+	int cur_cpu = -1;
+
+	/* BSP need os disable the irq */
+	local_irq_disable();
+
+	/*
+	 * Use an own vector here because smp_call_function
+	 * does lots of things not suitable in a panic situation.
+	 */
+	if (num_online_cpus() <= 1) {
+		printk(KERN_EMERG "%s:only one cpu is running!\n", __func__);
+		goto out;
+	}
+
+	/* record current cpu id, parallel not surpport */
+	cur_cpu = smp_processor_id();
+
+	/* juge last calling*/
+	if (atomic_read(&smp_call_not_finished) && (atomic_read(&calling_cpu) != -1)) {
+		printk(KERN_EMERG "%s:smp_call_not_finished,check smp_call_mask\n", __func__);
+		/* if other cpus completed */
+		if (cpumask_empty(to_cpumask(smp_call_mask))) {
+			atomic_set(&smp_call_not_finished, 0);
+			atomic_set(&calling_cpu, -1);
+		} else {
+			printk(KERN_EMERG "warning:last call not finished! cpu_mask = 0x%lx.\n",
+					*smp_call_mask);
+			return -1;
+		}
+	}
+
+	if (atomic_cmpxchg(&calling_cpu, -1, cur_cpu) != -1) {
+		cpu = atomic_read(&calling_cpu);
+		printk(KERN_EMERG "another cpu:%d is running! cur cpu = %d.\n",
+				cpu, cur_cpu);
+		return -1;
+	}
+
+	cpumask_copy(to_cpumask(smp_call_mask), cpu_online_mask);
+	cpumask_clear_cpu(cur_cpu, to_cpumask(smp_call_mask));
+	printk(KERN_EMERG "cpu %d will send nmi ,the cpumask = 0x%lx\n",
+			cur_cpu, *smp_call_mask);
+
+	/* regitster callback */
+	user_ipi_callback_data.func = run_func;
+	user_ipi_callback_data.info = data;
+
+	/* set the flag that others cpu not finish */
+	atomic_add(1, &smp_call_not_finished);
+
+	/*do not call console for console may hung*/
+	console_silent();
+
+	/* current cpu not call the registered function */
+	smp_cross_call(to_cpumask(smp_call_mask), IPI_USER_FUN);
+
+	/* async mode, exit */
+	if (!wait)
+		goto no_wait_exit;
+
+	/*
+	 * Don't wait longer than a second if the caller
+	 * didn't ask us to wait.
+	 */
+	if (time < 0)
+		timeout = USEC_PER_SEC;
+	else
+		timeout = min(USEC_PER_SEC, time);
+	while ((num_online_cpus() > 1) && (timeout--))
+		udelay(1);
+
+	/* all other cpus excuted callback function */
+	if (num_online_cpus() == 1) {
+		atomic_sub(1, &smp_call_not_finished);
+		printk(KERN_EMERG "%s in other cpu exec finished!\n", __func__);
+		/* reset global struct */
+		user_ipi_callback_data.func = NULL;
+		user_ipi_callback_data.info = 0;
+		atomic_set(&calling_cpu, -1);
+		goto out;
+	}
+
+no_wait_exit:
+	printk(KERN_EMERG "%s:async mode, i finished!\n", __func__);
+	printk(KERN_EMERG "%s:this time is running cpumask = 0x%lx\n",
+			__func__, *smp_call_mask);
+	goto out;
+
+out:
+	return 0;
+}
+
+void kbox_smp_nmi_call_function(smp_nmi_call_func_t run_func, unsigned long data, int wait, long time, void *msg)
+{
+	smp_nmi_call_function(run_func, data, wait, time);
+}
+EXPORT_SYMBOL(kbox_smp_nmi_call_function);
+#endif
