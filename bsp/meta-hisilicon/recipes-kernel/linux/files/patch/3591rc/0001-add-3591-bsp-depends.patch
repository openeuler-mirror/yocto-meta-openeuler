+
+static void *alloc_sg_mem_node(struct dw_mci *host, struct scatterlist *sg, int node)
+{
+	struct node_mem_info *node_info = select_node(host, node);
+	unsigned int length = sg_dma_len(sg);
+	void *mem_addr = node_info->node_mem_addr + node_info->offset;
+
+	node_info->offset += DIV_ROUND_UP_ULL(length, 4096) * 4096;
+	return mem_addr;
+}
+
+/*
+ * Parse a sg list to select the most suitable node
+ * The memory physical address on node 1 has an offset of 0x8000000000,
+ * so we use phy addr to determine the source node, master or slave.
+ * I must admit that it is very customized
+ */
+static int dw_mci_select_node(struct dw_mci *host, struct mmc_data *data, unsigned int sg_len)
+{
+	unsigned int slave_count = 0;
+	unsigned int i;
+	u64 mem_addr;
+
+	for (i = 0; i < sg_len; i++) {
+		mem_addr = sg_phys(&data->sg[i]);
+		if (mem_addr & 0x8000000000)
+			slave_count++;
+	}
+	return (slave_count <= (sg_len - slave_count)) ? 0 : 1;
+}
