	i2c5_ao:i2c5@c4170000{
		compatible = "hisilicon,udrv_i2c";
		#address-cells = <1>;
		#size-cells = <0>;
		reg = <0x0 0xc4170000 0 0x10000>;
		interrupts = <0x0 153 0x4>;
		recovery_by_subctrl;
		//i2c-sda-falling-time-ns = <0>;              not used
		//i2c-scl-internal-delay-ns = <0>;            not used
		//i2c-analog-filter-cutoff-frequency = <0>;   not used
		i2c-scl-falling-time-ns = <0>;
		i2c-sda-hold-time-ns = <0x14D>;
		i2c-scl-rising-time-ns = <0xA6>;
		i2c-digital-filter-width-ns = <0x21>;
		// 150M时钟
		clk_rate = <150000000>;
		bus_id = <5>;
		// 速率100k
		clock-frequency = <100000>;
	};

