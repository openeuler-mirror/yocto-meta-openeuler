
	i2c0_isp:i2c0@300170000{
		compatible = "hisilicon,udrv_i2c";
		#address-cells = <1>;
		#size-cells = <0>;
		reg = <0x3 0x00170000 0 0x10000>;
		interrupts = <0x0 247 0x4>;
		recovery_by_subctrl;
		//i2c-sda-falling-time-ns = <0>;              not used
		//i2c-scl-internal-delay-ns = <0>;            not used
		//i2c-analog-filter-cutoff-frequency = <0>;   not used
		i2c-scl-falling-time-ns = <0>;
		i2c-sda-hold-time-ns = <0x190>;
		i2c-scl-rising-time-ns = <0x1E8>;
		i2c-digital-filter-width-ns = <0x28>;
		// 125M时钟
		clk_rate = <125000000>;
		bus_id = <0>;
		// 速率100k
		clock-frequency = <100000>;
		// To enable the I2C 0, uncomment the following two lines and comment the pinctrl configuration of the SPI 3
		pinctrl-names = "default";
		pinctrl-0 = <&iomg000_pmx_idle &iomg001_pmx_idle>;
	};

	i2c1_isp:i2c1@300180000{
		compatible = "hisilicon,udrv_i2c";
