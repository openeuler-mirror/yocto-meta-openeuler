		hidvpp_sys2 {
			compatible = "hidvpp,dvpp,sys";
			#address-cells = <0x2>;
			#size-cells = <0x2>;
			subsys-id = <0x2>;

			dvpp_controler@0xca0c0000 {
				compatible = "hidvpp,dvpp,controler";
				reg = <0x0 0xca0c0000 0x0 0x10000>;
			};

			dvpp1_scheduler0@0xca050000 {
				compatible = "hidvpp,dvpp,scheduler";
				reg = <0x0 0xca050000 0x0 0x10000>;
				scheduler-id = <0x0>;
			};

			dvpp1_scheduler1@0xca850000 {
				compatible = "hidvpp,dvpp,scheduler";
				reg = <0x0 0xca850000 0x0 0x10000>;
				scheduler-id = <0x1>;
			};

			dvpp_smmu4 {
				compatible = "hisilicon,dvpp,smmu";
				reg = <0x0 0xca000000 0x0 0x40000>;
				iommus = <&dsmmu4 0x7F91>; // 0x7F9B is VPC0's sid in B300
				dma-coherent;
				dma-can-stall;
				pasid-bits = <16>; // for kernel 4.1
				pasid-num-bits = <16>; // for kernel 4.19
				index-in-subsys = <0x0>;
				smmu_id = <0x4>;
			};

			dvpp_smmu5 {
				compatible = "hisilicon,dvpp,smmu";
				reg = <0x0 0xca800000 0x0 0x40000>;
				iommus = <&dsmmu5 0x7F91>; // 0x7F9B is VPC0's sid in B300
				dma-coherent;
				dma-can-stall;
				pasid-bits = <16>; // for kernel 4.1
				pasid-num-bits = <16>; // for kernel 4.19
				index-in-subsys = <0x1>;
				smmu_id = <0x5>;
			};

			// vdec
			vdec2_0@0xca180000 {
				compatible = "hidvpp,dvpp,vdec";
