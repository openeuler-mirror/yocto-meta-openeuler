			src_remote_processor = "MDC_IPC_TSV_MBX6_RPID5_RX_ACPU1";
			des_remote_processor = "HI1910P_AICPU1_MBX6";
			src_bit = <1>;
			des_bit = <5>;
			index = <6>;
		};

		mailbox-7-tsv-rx-acpu2 {
			compatible = "HiIPCV230,rx-mailbox-normal";
			func = <0 0 1>;
			interrupts = <0 204 4>;
			src_remote_processor = "MDC_IPC_TSV_MBX7_RPID6_RX_ACPU2";
			des_remote_processor = "HI1910P_AICPU2_MBX7";
			src_bit = <2>;
			des_bit = <6>;
			index = <7>;
		};

		mailbox-8-tsv-rx-acpu3 {
			compatible = "HiIPCV230,rx-mailbox-normal";
			func = <0 0 1>;
			interrupts = <0 205 4>;
			src_remote_processor = "MDC_IPC_TSV_MBX8_RPID7_RX_ACPU3";
			des_remote_processor = "HI1910P_AICPU3_MBX1";
			src_bit = <3>;
			des_bit = <7>;
			index = <8>;
		};

		/*tsv tx normal unsafe mbx channel*/
		mailbox-1-acpu0-tx-tsv {
			compatible = "HiIPCV230,tx-mailbox-normal";
			func = <0 1 0>;
			src_remote_processor = "HI1910P_AICPU0_MBX1";
			des_remote_processor = "MDC_IPC_TSV_MBX1_RPID0_TX_ACPU0";
			src_bit = <4>;
			des_bit = <0>;
			index = <1>;
		};

		mailbox-2-acpu1-tx-tsv {
			compatible = "HiIPCV230,tx-mailbox-normal";
			func = <0 1 0>;
			src_remote_processor = "HI1910P_AICPU1_MBX2";
			des_remote_processor = "MDC_IPC_TSV_MBX2_RPID1_TX_ACPU1";
			src_bit = <5>;
			des_bit = <1>;
			index = <2>;
		};

		mailbox-3-acpu2-tx-tsv {
			compatible = "HiIPCV230,tx-mailbox-normal";
			func = <0 1 0>;
			src_remote_processor = "HI1910P_AICPU2_MBX3";
			des_remote_processor = "MDC_IPC_TSV_MBX3_RPID2_TX_ACPU2";
			src_bit = <6>;
			des_bit = <2>;
			index = <3>;
		};

		mailbox-4-acpu3-tx-acpu3 {
			compatible = "HiIPCV230,tx-mailbox-normal";
			func = <0 1 0>;
			src_remote_processor = "HI1910P_AICPU3_MBX4";
			des_remote_processor = "MDC_IPC_TSV_MBX4_RPID3_TX_ACPU3";
			src_bit = <7>;
			des_bit = <3>;
			index = <4>;
		};
	};

	/* ISP IPC Mailbox
	 * 1. Only use Unsafe Quick channel
	 * 2. Use common channels' interrupts as ack
	 * 3. Three tx channels but one ack interrupt
	 * 4. 4 ipc devices, 24 channels, 16 interrupts
	 */
	/* ISP0_IPC0 */
	hisi_isp_ipc4_p0: cluster0-p0@A9330000 {
		#address-cells = <2>;
		#sizec-cells = <2>;
		compatible = "HiIPCV230,hisi-ipc-isp0-ipc0";
		reg = <0x0 0xA9330000 0x0 0xB000>;
		/* Three channels but one ack, write 4 for align */
		interrupts = <0 278 4>, <0 278 4>, <0 278 4>, <0 278 4>;
		unlock_key = <0x1ACCE551>;
		capability = <8>;
		mailboxes = <6>;

		/* RX */
		mailbox-0-isp0-ipc0-1-rx-acpu0 {
			compatible = "HiIPCV230,rx-mailbox-fast";
			func = <1 0 1>;
			interrupts = <0 272 4>;
			irq_affinity = <10>;
			src_remote_processor = "IPC_ISP0_IPC0_MBX0_RPID0_Q_RX_ACPU0";
			des_remote_processor = "RX_DES_ACPU0_ID4_MBX0";
			src_bit = <1>;
			des_bit = <0>;
			index = <0>;
		};

		mailbox-1-isp0-ipc0-2-rx-acpu0 {
			compatible = "HiIPCV230,rx-mailbox-fast";
			func = <1 0 1>;
			interrupts = <0 273 4>;
			irq_affinity = <10>;
			src_remote_processor = "IPC_ISP0_IPC0_MBX1_RPID0_Q_RX_ACPU0";
			des_remote_processor = "RX_DES_ACPU0_ID4_MBX1";
			src_bit = <2>;
			des_bit = <0>;
			index = <1>;
		};

		mailbox-2-isp0-ipc0-3-rx-acpu0 {
			compatible = "HiIPCV230,rx-mailbox-fast";
			func = <1 0 1>;
			interrupts = <0 274 4>;
			irq_affinity = <10>;
			src_remote_processor = "IPC_ISP0_IPC0_MBX2_RPID0_Q_RX_ACPU0";
			des_remote_processor = "RX_DES_ACPU0_ID4_MBX2";
			src_bit = <3>;
			des_bit = <0>;
			index = <2>;
		};

		/* TX */
		mailbox-6-acpu0-tx-isp0-ipc0-1 {
			compatible = "HiIPCV230,tx-mailbox-fast";
			func = <1 1 0>;
			src_remote_processor = "TX_SRC_ISP0_IPC0_ID4_MBX6";
			des_remote_processor = "IPC_ISP0_IPC0_MBX6_RPID0_Q_TX_ACPU0";
			src_bit = <0>;
			des_bit = <1>;
			index = <6>;
		};

		mailbox-7-acpu0-tx-isp0-ipc0-2 {
			compatible = "HiIPCV230,tx-mailbox-fast";
			func = <1 1 0>;
			src_remote_processor = "TX_SRC_ISP0_IPC0_ID4_MBX7";
			des_remote_processor = "IPC_ISP0_IPC0_MBX7_RPID0_Q_TX_ACPU0";
			src_bit = <0>;
			des_bit = <2>;
			index = <7>;
		};

		mailbox-8-acpu0-tx-isp0-ipc0-3 {
			compatible = "HiIPCV230,tx-mailbox-fast";
			func = <1 1 0>;
			src_remote_processor = "TX_SRC_ISP0_IPC0_ID4_MBX8";
			des_remote_processor = "IPC_ISP0_IPC0_MBX8_RPID0_Q_TX_ACPU0";
			src_bit = <0>;
			des_bit = <3>;
			index = <8>;
		};
	};
	/* ISP0-IPC1 */
	hisi_isp_ipc5_p0: cluster1-p0@A9730000 {
		#address-cells = <2>;
		#size-cells = <2>;
		compatible = "HiIPCV230,hisi-ipc-isp0-ipc1";
		reg = <0x0 0xA9730000 0x0 0xB000>;
		interrupts = <0 279 4>, <0 279 4>, <0 279 4>, <0 279 4>;
		unlock_key = <0x1ACCE551>;
		capability = <8>;
		mailboxes = <6>;

		/* RX */
		mailbox-0-isp0-ipc1-1-rx-acpu0 {
			compatible = "HiIPCV230,rx-mailbox-fast";
			func = <1 0 1>;
			interrupts = <0 275 4>;
			irq_affinity = <10>;
			src_remote_processor = "IPC_ISP0_IPC1_MBX0_RPID0_Q_RX_ACPU0";
			des_remote_processor = "RX_DES_ISP0_IPC1_ID5_MBX0";
			src_bit = <1>;
			des_bit = <0>;
			index = <0>;
		};

		mailbox-1-isp0-ipc1-2-rx-acpu0 {
			compatible = "HiIPCV230,rx-mailbox-fast";
			func = <1 0 1>;
			interrupts = <0 276 4>;
			irq_affinity = <10>;
			src_remote_processor = "IPC_ISP0_IPC1_MBX1_RPID0_Q_RX_ACPU0";
			des_remote_processor = "RX_DES_ISP0_IPC1_ID5_MBX1";
			src_bit = <2>;
			des_bit = <0>;
			index = <1>;
		};

		mailbox-2-isp0-ipc0-3-rx-acpu0 {
			compatible = "HiIPCV230,rx-mailbox-fast";
			func = <1 0 1>;
			interrupts = <0 277 4>;
			irq_affinity = <10>;
			src_remote_processor = "IPC_ISP0_IPC1_MBX2_RPID0_Q_RX_ACPU0";
			des_remote_processor = "RX_DES_ISP0_IPC1_ID5_MBX2";
			src_bit = <3>;
			des_bit = <0>;
			index = <2>;
		};

		/* TX */
		mailbox-6-acpu0-tx-isp0-ipc1-1 {
			compatible = "HiIPCV230,tx-mailbox-fast";
			func = <1 1 0>;
			src_remote_processor = "TX_SRC_ISP0_IPC1_ID5_MBX6";
			des_remote_processor = "IPC_ISP0_IPC1_MBX6_RPID0_Q_TX_ACPU0";
			src_bit = <0>;
			des_bit = <1>;
			index = <6>;
		};

		mailbox-7-acpu0-tx-isp0-ipc1-2 {
