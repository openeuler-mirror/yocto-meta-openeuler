hisi_ipc_device_0 {
	#address-cells = <2>;
	#size-cells = <2>;

	compatible = "hisi,hi-miniv2-ipcdrv";
	mailboxes = <80>;
	ipc_id = <0>;
	ranges;

	/* ipc safe island quick unsafe mailbox */
	hisi_si_ipc0_p0: si-p0@cf090000 {
		#address-cells = <2>;
		#size-cells = <2>;
		compatible = "HiIPCV230,hisi-ipc-si";
		reg = <0x0 0xCF090000 0x0 0xB000>;
		interrupts = <0 194 4>, <0 261 4>, <0 265 4>, <0 281 4>;
			     /*ACPU0     ACPU1       ACPU2         ACPU3 */
		unlock_key = <0x1ACCE551>;
		capability = <8>;
		mailboxes = <8>;

		/*
		 * "func"
		 * <mbox_type, is_src_mbox, is_des_mbox>;
		 */

		/*si rx quick unsafe mbx channel*/
		mailbox-0-si-rx-acpu0 {
			compatible = "HiIPCV230,rx-mailbox-fast";
			func = <1 0 1>;
			interrupts = <0 193 4>;
			src_remote_processor = "MDC_IPC_SI_MBX0_RPID0_Q_RX_ACPU0";
			des_remote_processor = "HI1910P_AICPU0_MBX0";
			src_bit = <14>;
			des_bit = <0>;
			index = <0>;
		};

		mailbox-1-si-rx-acpu1 {
			compatible = "HiIPCV230,rx-mailbox-fast";
			func = <1 0 1>;
			interrupts = <0 260 4>;
			src_remote_processor = "MDC_IPC_SI_MBX1_RPID1_Q_RX_ACPU1";
			des_remote_processor = "HI1910P_AICPU1_MBX1";
			src_bit = <15>;
			des_bit = <1>;
			index = <1>;
		};

		mailbox-2-si-rx-acpu2 {
			compatible = "HiIPCV230,rx-mailbox-fast";
			func = <1 0 1>;
			interrupts = <0 264 4>;
			src_remote_processor = "MDC_IPC_SI_MBX2_RPID2_Q_RX_ACPU2";
			des_remote_processor = "HI1910P_AICPU2_MBX2";
			src_bit = <16>;
			des_bit = <2>;
			index = <2>;
		};

		mailbox-3-si-rx-acpu3 {
			compatible = "HiIPCV230,rx-mailbox-fast";
			func = <1 0 1>;
			interrupts = <0 280 4>;
			src_remote_processor = "MDC_IPC_SI_MBX3_RPID3_Q_RX_ACPU3";
			des_remote_processor = "HI1910P_AICPU3_MBX3";
			src_bit = <17>;
			des_bit = <3>;
			index = <3>;
		};

		/*si tx quick unsafe mbx channel*/
		mailbox-14-acpu0-tx-si {
			compatible = "HiIPCV230,tx-mailbox-fast";
			func = <1 1 0>;
			src_remote_processor = "HI1910P_AICPU0_MBX14";
			des_remote_processor = "MDC_IPC_SI_MBX14_RPID14_Q_TX_ACPU0";
			src_bit = <0>;
			des_bit = <14>;
			index = <14>;
		};

		mailbox-15-acpu1-tx-si {
			compatible = "HiIPCV230,tx-mailbox-fast";
			func = <1 1 0>;
			src_remote_processor = "HI1910P_AICPU1_MBX15";
			des_remote_processor = "MDC_IPC_SI_MBX15_RPID15_Q_TX_ACPU1";
			src_bit = <1>;
			des_bit = <15>;
			index = <15>;
		};

		mailbox-16-acpu2-tx-si {
			compatible = "HiIPCV230,tx-mailbox-fast";
			func = <1 1 0>;
			src_remote_processor = "HI1910P_AICPU2_MBX16";
			des_remote_processor = "MDC_IPC_SI_MBX16_RPID16_Q_TX_ACPU2";
			src_bit = <2>;
			des_bit = <16>;
			index = <16>;
		};

		mailbox-17-acpu3-tx-si {
			compatible = "HiIPCV230,tx-mailbox-fast";
			func = <1 1 0>;
			src_remote_processor = "HI1910P_AICPU3_MBX17";
			des_remote_processor = "MDC_IPC_SI_MBX17_RPID17_Q_TX_ACPU3";
			src_bit = <3>;
			des_bit = <17>;
			index = <17>;
		};

	};

	/* ipc LP quick unsafe mailbox */
	hisi_lp_ipc1_p0: lp-p0@84870000 {
		#address-cells = <2>;
		#size-cells = <2>;
		compatible = "HiIPCV230,hisi-ipc-lp";
		reg = <0x0 0x84870000 0x0 0xB000>;
		interrupts = <0 189 4>, <0 190 4>, <0 191 4>, <0 192 4>;
			     /*ACPU0     ACPU1       ACPU2         ACPU3 */

		unlock_key = <0x1ACCE551>;
		capability = <8>;
		mailboxes = <8>;

		/*
		 * "func"
		 * <mbox_type, is_src_mbox, is_des_mbox>;
		 */
		/*lp rx quick unsafe mbx channel*/
		mailbox-0-lp-rx-acpu0 {
			compatible = "HiIPCV230,rx-mailbox-fast";
			func = <1 0 1>;
			interrupts = <0 178 4>;
			src_remote_processor = "MDC_IPC_LP_MBX0_RPID0_Q_RX_ACPU0";
			des_remote_processor = "HI1910P_AICPU0_MBX0";
			src_bit = <4>;
			des_bit = <0>;
			index = <0>;
		};

		mailbox-1-lp-rx-acpu1 {
			compatible = "HiIPCV230,rx-mailbox-fast";
			func = <1 0 1>;
			interrupts = <0 179 4>;
			src_remote_processor = "MDC_IPC_LP_MBX1_RPID1_Q_RX_ACPU1";
			des_remote_processor = "HI1910P_AICPU1_MBX1";
			src_bit = <4>;
			des_bit = <1>;
			index = <1>;
		};

		mailbox-2-lp-rx-acpu2 {
			compatible = "HiIPCV230,rx-mailbox-fast";
			func = <1 0 1>;
			interrupts = <0 180 4>;
			src_remote_processor = "MDC_IPC_LP_MBX2_RPID2_Q_RX_ACPU2";
			des_remote_processor = "HI1910P_AICPU2_MBX2";
			src_bit = <4>;
			des_bit = <2>;
			index = <2>;
		};

		mailbox-3-lp-rx-acpu3 {
			compatible = "HiIPCV230,rx-mailbox-fast";
			func = <1 0 1>;
			interrupts = <0 181 4>;
			src_remote_processor = "MDC_IPC_LP_MBX3_RPID3_Q_RX_ACPU3";
			des_remote_processor = "HI1910P_AICPU3_MBX3";
			src_bit = <4>;
			des_bit = <3>;
			index = <3>;
		};

		/*lp tx quick unsafe mbx channel*/
		mailbox-8-acpu0-tx-lp {
			compatible = "HiIPCV230,tx-mailbox-fast";
			func = <1 1 0>;
			src_remote_processor = "HI1910P_AICPU0_MBX8";
			des_remote_processor = "MDC_IPC_LP_MBX8_RPID4_Q_TX_ACPU0";
			src_bit = <0>;
			des_bit = <4>;
			index = <8>;
		};

		mailbox-9-acpu1-tx-lp {
			compatible = "HiIPCV230,tx-mailbox-fast";
			func = <1 1 0>;
			src_remote_processor = "HI1910P_AICPU1_MBX9";
			des_remote_processor = "MDC_IPC_LP_MBX9_RPID4_Q_TX_ACPU1";
			src_bit = <1>;
			des_bit = <4>;
			index = <9>;
		};

		mailbox-10-acpu2-tx-lp {
			compatible = "HiIPCV230,tx-mailbox-fast";
			func = <1 1 0>;
			src_remote_processor = "HI1910P_AICPU2_MBX10";
			des_remote_processor = "MDC_IPC_LP_MBX10_RPID4_Q_TX_ACPU2";
			src_bit = <2>;
			des_bit = <4>;
			index = <10>;
		};

		mailbox-11-acpu3-tx-lp {
			compatible = "HiIPCV230,tx-mailbox-fast";
			func = <1 1 0>;
			src_remote_processor = "HI1910P_AICPU3_MBX11";
			des_remote_processor = "MDC_IPC_LP_MBX11_RPID4_Q_TX_ACPU3";
			src_bit = <3>;
			des_bit = <4>;
			index = <11>;
		};
	};

	/* ipc tsc normal unsafe mailbox */
	hisi_tsc_ipc2_p0: tsc-p0@BA0A0000 {
		#address-cells = <2>;
		#size-cells = <2>;
		compatible = "HiIPCV230,hisi-ipc-tsc";
		reg = <0x0 0xBA0A0000 0x0 0xB000>;
		interrupts = <0 224 4>, <0 225 4>, <0 226 4>, <0 227 4>;
			     /*ACPU0     ACPU1       ACPU2         ACPU3 */

		unlock_key = <0x1ACCE551>;
		capability = <8>;
		mailboxes = <8>;

		/*
		 * "func"
		 * <mbox_type, is_src_mbox, is_des_mbox>;
		 */
		/*tsc rx normal unsafe mbx channel*/
		mailbox-5-tsc-rx-acpu0 {
			compatible = "HiIPCV230,rx-mailbox-normal";
			func = <0 0 1>;
			interrupts = <0 224 4>;
			src_remote_processor = "MDC_IPC_TSC_MBX5_RPID4_RX_ACPU0";
			des_remote_processor = "HI1910P_AICPU0_MBX5";
			src_bit = <0>;
			des_bit = <4>;
			index = <5>;
		};

		mailbox-6-tsc-rx-acpu1 {
			compatible = "HiIPCV230,rx-mailbox-normal";
			func = <0 0 1>;
			interrupts = <0 225 4>;
			src_remote_processor = "MDC_IPC_TSC_MBX6_RPID5_RX_ACPU1";
			des_remote_processor = "HI1910P_AICPU1_MBX6";
