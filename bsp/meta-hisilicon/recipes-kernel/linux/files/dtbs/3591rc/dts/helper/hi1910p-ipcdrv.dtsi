			func = <0 0 1>;
			interrupts = <0 226 4>;
			src_remote_processor = "MDC_IPC_TSC_MBX7_RPID6_RX_ACPU2";
			des_remote_processor = "HI1910P_AICPU2_MBX7";
			src_bit = <2>;
			des_bit = <6>;
			index = <7>;
		};

		mailbox-8-tsc-rx-acpu3 {
			compatible = "HiIPCV230,rx-mailbox-normal";
			func = <0 0 1>;
			interrupts = <0 227 4>;
			src_remote_processor = "MDC_IPC_TSC_MBX8_RPID7_RX_ACPU3";
			des_remote_processor = "HI1910P_AICPU3_MBX1";
			src_bit = <3>;
			des_bit = <7>;
			index = <8>;
		};

		/*tsc tx normal unsafe mbx channel*/
		mailbox-1-acpu0-tx-tsc {
			compatible = "HiIPCV230,tx-mailbox-normal";
			func = <0 1 0>;
			src_remote_processor = "HI1910P_AICPU0_MBX1";
			des_remote_processor = "MDC_IPC_TSC_MBX1_RPID0_TX_ACPU0";
			src_bit = <4>;
			des_bit = <0>;
			index = <1>;
		};

		mailbox-2-acpu1-tx-tsc {
			compatible = "HiIPCV230,tx-mailbox-normal";
			func = <0 1 0>;
			src_remote_processor = "HI1910P_AICPU1_MBX2";
			des_remote_processor = "MDC_IPC_TSC_MBX2_RPID1_TX_ACPU1";
			src_bit = <5>;
			des_bit = <1>;
			index = <2>;
		};

		mailbox-3-acpu2-tx-tsc {
			compatible = "HiIPCV230,tx-mailbox-normal";
			func = <0 1 0>;
			src_remote_processor = "HI1910P_AICPU2_MBX3";
			des_remote_processor = "MDC_IPC_TSC_MBX3_RPID2_TX_ACPU2";
			src_bit = <6>;
			des_bit = <2>;
			index = <3>;
		};

		mailbox-4-acpu3-tx-tsc {
			compatible = "HiIPCV230,tx-mailbox-normal";
			func = <0 1 0>;
			src_remote_processor = "HI1910P_AICPU3_MBX4";
			des_remote_processor = "MDC_IPC_TSC_MBX4_RPID3_TX_ACPU3";
			src_bit = <7>;
			des_bit = <3>;
			index = <4>;
		};
	};

	/* ipc tsv normal unsafe mailbox */
	hisi_tsv_ipc3_p0: tsv-p0@B90A0000 {
		#address-cells = <2>;
		#size-cells = <2>;
		compatible = "HiIPCV230,hisi-ipc-tsv";
		reg = <0x0 0xB90A0000 0x0 0xB000>;
		interrupts = <0 202 4>, <0 203 4>, <0 204 4>, <0 205 4>;
			     /*ACPU0     ACPU1       ACPU2         ACPU3 */

		unlock_key = <0x1ACCE551>;
		capability = <8>;
		mailboxes = <8>;
		/*
		 * "func"
		 * <mbox_type, is_src_mbox, is_des_mbox>;
		 */

		/*tsv rx normal unsafe mbx channel*/
		mailbox-5-tsv-rx-acpu0 {
			compatible = "HiIPCV230,rx-mailbox-normal";
			func = <0 0 1>;
			interrupts = <0 202 4>;
			src_remote_processor = "MDC_IPC_TSV_MBX5_RPID4_RX_ACPU0";
			des_remote_processor = "HI1910P_AICPU0_MBX5";
			src_bit = <0>;
			des_bit = <4>;
			index = <5>;
		};

		mailbox-6-tsv-rx-acpu1 {
			compatible = "HiIPCV230,rx-mailbox-normal";
