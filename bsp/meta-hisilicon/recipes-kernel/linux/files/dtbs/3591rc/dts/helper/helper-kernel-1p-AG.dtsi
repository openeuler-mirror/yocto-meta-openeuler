	cpu15:cpu@15 {
	    device_type = "cpu";
	    compatible = "arm,armv8";
	    reg = <0xb0300>;
	    enable-method = "psci";
            cpu-release-addr = <0x0 0xfff8>;
            numa-node-id = <0>;
	};

        psci {
            compatible = "arm,psci-0.2";
            method = "smc";
        };
    };

    interrupt-controller@85000000 {
        compatible = "arm,gic-v3";
        #interrupt-cells = <0x3>;
        #address-cells = <0x2>;
        #size-cells = <0x2>;
        ranges;
        interrupt-controller;
        #redistributor-regions = <0x1>;
        redistributor-stride = <0x0 0x40000>;
        reg = <0x0 0x85000000 0x0 0x10000>,    /* GICD */
              <0x0 0x85100000 0x0 0x800000>;    /* GICR1: CPUS 0-31 */
        interrupts = <0x1 0x9 0xff04>;
        linux,phandle = <0x1>;
        phandle = <0x1>;

        its: interrupt-controller@87000000 {
            compatible = "arm,gic-v3-its";
            msi-controller;
            #msi-cells = <0x1>;
            reg = <0x0 0x87000000 0x0 0x40000>;
        };
    };

    timer {
        compatible = "arm,armv8-timer";
        interrupts = <0x1 0xd 0xff08>,    /* secure */
                     <0x1 0xe 0xff08>,    /* non-secure */
                     <0x1 0xb 0xff08>,    /* virtual */
                     <0x1 0xa 0xff08>;    /* hypervisor */
    };

    pmu {
	compatible = "arm,armv8-pmuv3";
	interrupts = <0x1 0x7 0x4>;
    };


    memory0@numa0 {
        device_type = "memory";
        reg = <0x0 0xB101000 0x0 0x1FF000>, //For log_redirect
              <0x0 0x29501000 0x0 0x10000>, //For apei table
              <0x0 0x31D00000 0x0 0x4E300000>; // for dma32
        numa-node-id = <0>;
    };

    memory0_ts0@numa0 {
        device_type = "memory";
        reg = <0x8 0x80000000 0x0 0x3A200000>;
        numa-node-id = <2>;
    };

    memory_add@numa0 {
        device_type = "memory";
        reg = <0x8 0xBA200000 0x0 0x0>;
        numa-node-id = <0>;  // node0 for OS
    };

    soc_pmu {
        compatible = "simple-bus";
        #address-cells = <0x2>;
        #size-cells = <0x2>;
        ranges;

        l3t0@81170000 {
            compatible = "hisilicon,l3t-pmu";
			hisilicon,scl-id = <1>;
			hisilicon,ccl-id = <0>;
			hisilicon,index-id = <1>;
            reg = <0x0 0x81170000 0x0 0x10000>;
			interrupts = <0x0 316 0x4>;
		};

        l3t1@81180000 {
            compatible = "hisilicon,l3t-pmu";
			hisilicon,scl-id = <1>;
			hisilicon,ccl-id = <0>;
			hisilicon,index-id = <2>;
            reg = <0x0 0x81180000 0x0 0x10000>;
			interrupts = <0x0 316 0x4>;
		};

        l3t2@81190000 {
            compatible = "hisilicon,l3t-pmu";
			hisilicon,scl-id = <1>;
			hisilicon,ccl-id = <0>;
