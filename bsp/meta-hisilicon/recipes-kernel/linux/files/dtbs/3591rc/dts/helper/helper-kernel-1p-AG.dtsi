    cpus {
        #address-cells = <0x1>;
        #size-cells = <0x0>;

        cpu0:cpu@0 {
            device_type = "cpu";
            compatible = "arm,armv8";
            reg = <0x80000>;
            enable-method = "psci";
            cpu-release-addr = <0x0 0xfff8>;
            numa-node-id = <0>;
        };

	cpu1:cpu@1 {
	    device_type = "cpu";
            compatible = "arm,armv8";
            reg = <0x80100>;
            enable-method = "psci";
            cpu-release-addr = <0x0 0xfff8>;
            numa-node-id = <0>;
	};

	cpu2:cpu@2 {
	    device_type = "cpu";
            compatible = "arm,armv8";
            reg = <0x80200>;
            enable-method = "psci";
            cpu-release-addr = <0x0 0xfff8>;
            numa-node-id = <0>;
	};

	cpu3:cpu@3 {
	    device_type = "cpu";
