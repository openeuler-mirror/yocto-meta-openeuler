    reserved-memory {
        #address-cells = <0x2>;
        #size-cells = <0x2>;
        ranges;

        pcie_reserved: pcie@0x0 {
            no-map;
            reg = <0x0 0x0 0x0 0x900000>;
        };

        aicpufw_config_reserved@9fe000 {
            compatible = "aicpufw_config_reserve_mem";
            no-map;
            reg_num = <0x1>;
            reg = <0x0 0x9fe000 0x0 0x2000>;
        };

        devdrv_sqcq_reserved@bb00000 {
            compatible = "devdrv_sqcq_reserve_mem";
            no-map;
            reg_num = <0x1>;
            reg = <0x0 0xbb00000 0x0 0x4000000>;
        };

        tsfw_reserved@fb00000 {
            compatible = "tsfw_reserve_mem";
            no-map;
            reg_num = <0x1>;
            reg = <0x0 0xfb00000 0x0 0x17200000>;
        };

        aicpu_mailbox_reserved@29500000 {
            compatible = "aicpu_mailbox_reserve_mem";
            no-map;
            reg_num = <0x1>;
            reg = <0x0 0x29500000 0x0 0x1000>;
        };

        hest_reserved@29501000 {
            reg_num = <0x1>;
            reg = <0x0 0x29501000 0x0 0x10000>;
        };

        cq_uio_mem@2B981000 {
            compatible = "cq_uio_mem_reserve_mem";
            no-map;
            reg_num = <0x1>;
            reg = <0x0 0x2BB81000 0x0 0xE00000>;
        };

        va2pa_trunk: trunk@0x2C981000 {
            compatible = "va2pa trunk";
            no-map;
            reg = <0x0 0x2C981000 0x0 0x1900000>;
        };

        blackbox_reserved: bboxbuffer@0x2F900000 {
            compatible = "bbox buffer";
            no-map;
            reg = <0x0 0x2F900000 0x0 0x1E00000>;
        };
    };

    mbuff@1100c0000 {
        compatible = "buff_manage,hi-buff-manage";
    };

    hisi_hest@29501000 {
        compatible = "dt_apei, hest";
        reg = <0x0 0x29501000 0x0 0x10000>;
        /* type:  0: SPI
         * num:   342
         * Trig type 04:high
         */
        interrupts = <0x0 0x136 0x4>;
    };

    os_kbox {
        compatible = "os_kbox";
        reg = <0x0 0x309A0000 0x0 0x500000>;
    };
