            reg = <0x0 0x81190000 0x0 0x10000>;
			interrupts = <0x0 316 0x4>;
		};

        l3t3@811A0000 {
            compatible = "hisilicon,l3t-pmu";
			hisilicon,scl-id = <1>;
			hisilicon,ccl-id = <0>;
			hisilicon,index-id = <4>;
            reg = <0x0 0x811A0000 0x0 0x10000>;
			interrupts = <0x0 316 0x4>;
		};

		lpddrc0@A5800000 {
            compatible = "hisilicon,lpddrc-pmu";
            hisilicon,ch-id = <0>;
			hisilicon,scl-id = <1>;
            reg = <0x0 0xA5800000 0x0 0x10000>;
