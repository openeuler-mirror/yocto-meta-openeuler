	gpio7:gpio@400150000 {
		compatible = "hisilicon,udrv_gpio";
		reg = <0x4 0x00150000 0x0 0x10000>;
		base = <0xe0>;
		ngpios = <0x20>;
		host_id = <7>;
		gpio-controller;
		#gpio-cells = <2>;
		interrupt-controller;
		#interrupt-cells = <2>;
		interrupts = <0x0 151 0x4>;
