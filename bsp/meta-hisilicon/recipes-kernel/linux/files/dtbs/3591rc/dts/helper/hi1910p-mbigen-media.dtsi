            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <0x20>;
        };
        mbigen_dvpp2_vdec1: dvpp2_vdec1 {
            msi-parent = <&its 0x7F68>;
            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <0x20>;
        };
        mbigen_dvpp2_vdec2: dvpp2_vdec2 {
            msi-parent = <&its 0x7F69>;
            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <0x20>;
        };
        mbigen_dvpp2_vdec3: dvpp2_vdec3 {
            msi-parent = <&its 0x7F6A>;
            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <0x20>;
        };

        // dvpp2 jpeg0
        mbigen_dvpp2_jpeg0_jpegd0: dvpp2_jpeg0_jpegd0 {
            msi-parent = <&its 0x7F6C>; // device num: 0x0F5D
            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <0x20>;
        };
        mbigen_dvpp2_jpeg0_jpegd1: dvpp2_jpeg0_jpegd1 {
            msi-parent = <&its 0x7F6D>; // device num: 0x0F5D
            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <0x20>;
        };
        mbigen_dvpp2_jpeg0_jpege0: dvpp2_jpeg0_jpege0 {
            msi-parent = <&its 0x7F6E>; // device num: 0x0F5F
            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <0x20>;
        };

        // dvpp 2 jpeg1
        mbigen_dvpp2_jpeg1_jpegd0: dvpp2_jpeg1_jpegd0 {
            msi-parent = <&its 0x7F70>; // device num: 0x0F5D
            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <0x20>;
        };
        mbigen_dvpp2_jpeg1_jpegd1: dvpp2_jpeg1_jpegd1 {
            msi-parent = <&its 0x7F71>; // device num: 0x0F5D
            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <0x20>;
        };
        mbigen_dvpp2_jpeg1_jpege0: dvpp2_jpeg1_jpege0 {
            msi-parent = <&its 0x7F72>; // device num: 0x0F5F
            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <0x20>;
