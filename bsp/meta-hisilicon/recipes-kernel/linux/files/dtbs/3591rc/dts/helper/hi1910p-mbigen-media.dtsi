    media_mbigen: media_mbigen@FA6F0000 {
        compatible = "hisilicon,mbigen-v2";
        reg = <0x0 0xfa6f0000 0x0 0x10000>;
        // dvpp 0 vdec
        mbigen_dvpp0_vdec0: dvpp0_vdec0 {
            msi-parent = <&its 0x7F49>;
            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <0x20>;
        };
        mbigen_dvpp0_vdec1: dvpp0_vdec1 {
            msi-parent = <&its 0x7F4A>;
            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <0x20>;
        };
        mbigen_dvpp0_vdec2: dvpp0_vdec2 {
            msi-parent = <&its 0x7F4B>;
            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <0x20>;
        };
        mbigen_dvpp0_vdec3: dvpp0_vdec3 {
            msi-parent = <&its 0x7F4C>;
            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <0x20>;
        };

        // dvpp 0 jpeg0
        mbigen_dvpp0_jpeg0_jpegd0: dvpp0_jpeg0_jpegd0 {
            msi-parent = <&its 0x7F4E>; // device num: 0x0F5D
            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <0x20>;
        };
        mbigen_dvpp0_jpeg0_jpegd1: dvpp0_jpeg0_jpegd1 {
            msi-parent = <&its 0x7F4F>; // device num: 0x0F5D
            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <0x20>;
        };
        mbigen_dvpp0_jpeg0_jpege0: dvpp0_jpeg0_jpege0 {
            msi-parent = <&its 0x7F50>; // device num: 0x0F5F
            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <0x20>;
        };

        // dvpp 0 jpeg1
        mbigen_dvpp0_jpeg1_jpegd0: dvpp0_jpeg1_jpegd0 {
            msi-parent = <&its 0x7F52>; // device num: 0x0F5D
            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <0x20>;
        };
        mbigen_dvpp0_jpeg1_jpegd1: dvpp0_jpeg1_jpegd1 {
            msi-parent = <&its 0x7F53>; // device num: 0x0F5D
            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <0x20>;
