            #interrupt-cells = <0x2>;
            num-pins = <0x20>;
        };

        // dvpp 1 vdec
        mbigen_dvpp1_vdec0: dvpp1_vdec0 {
            msi-parent = <&its 0x7F58>;
            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <0x20>;
        };
        mbigen_dvpp1_vdec1: dvpp1_vdec1 {
            msi-parent = <&its 0x7F59>;
            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <0x20>;
        };
        mbigen_dvpp1_vdec2: dvpp1_vdec2 {
            msi-parent = <&its 0x7F5A>;
            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <0x20>;
        };
        mbigen_dvpp1_vdec3: dvpp1_vdec3 {
            msi-parent = <&its 0x7F5B>;
            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <0x20>;
        };

        // dvpp1 jpeg0
        mbigen_dvpp1_jpeg0_jpegd0: dvpp1_jpeg0_jpegd0 {
            msi-parent = <&its 0x7F5D>; // device num: 0x0F5D
            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <0x20>;
        };
        mbigen_dvpp1_jpeg0_jpegd1: dvpp1_jpeg0_jpegd1 {
            msi-parent = <&its 0x7F5E>; // device num: 0x0F5D
            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <0x20>;
        };
        mbigen_dvpp1_jpeg0_jpege0: dvpp1_jpeg0_jpege0 {
            msi-parent = <&its 0x7F5F>; // device num: 0x0F5F
            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <0x20>;
        };

        // dvpp 1 jpeg1
        mbigen_dvpp1_jpeg1_jpegd0: dvpp1_jpeg1_jpegd0 {
            msi-parent = <&its 0x7F61>; // device num: 0x0F5D
