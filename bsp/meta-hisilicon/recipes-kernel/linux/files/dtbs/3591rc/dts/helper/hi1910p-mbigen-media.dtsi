            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <0x20>;
        };
        mbigen_dvpp1_jpeg1_jpege0: dvpp1_jpeg1_jpege0 {
            msi-parent = <&its 0x7F63>; // device num: 0x0F5F
            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <0x20>;
        };

        // dvpp 1 jpeg2
        mbigen_dvpp1_jpeg2_jpegd0: dvpp1_jpeg2_jpegd0 {
            msi-parent = <&its 0x7F7D>; // device num: 0x0F5D
            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <0x20>;
        };
        mbigen_dvpp1_jpeg2_jpegd1: dvpp1_jpeg2_jpegd1 {
            msi-parent = <&its 0x7F7E>; // device num: 0x0F5D
            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <0x20>;
        };
        mbigen_dvpp1_jpeg2_jpege0: dvpp1_jpeg2_jpege0 {
            msi-parent = <&its 0x7F7F>; // device num: 0x0F5F
            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <0x20>;
        };

        // dvpp 1 jpeg3
        mbigen_dvpp1_jpeg3_jpegd0: dvpp1_jpeg3_jpegd0 {
            msi-parent = <&its 0x7F79>; // device num: 0x0F5D
            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <0x20>;
        };
        mbigen_dvpp1_jpeg3_jpegd1: dvpp1_jpeg3_jpegd1 {
            msi-parent = <&its 0x7F7A>; // device num: 0x0F5D
            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <0x20>;
        };
        mbigen_dvpp1_jpeg3_jpege0: dvpp1_jpeg3_jpege0 {
            msi-parent = <&its 0x7F7B>; // device num: 0x0F5F
