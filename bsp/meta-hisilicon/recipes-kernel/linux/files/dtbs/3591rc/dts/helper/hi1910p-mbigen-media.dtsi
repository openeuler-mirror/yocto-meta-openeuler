        mbigen_vpc_err: vpc_err {
            msi-parent = <&its 0x7F77>; // device num: 0x0F77
            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <0x20>;
        };

        mbigen_retr: retr_inc {
            msi-parent = <&its 0x7f76>;
            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <1>;
        };

        mbigen_dss: mbigen-v2-dss {
            msi-parent = <&its 0x7F80>;
            interrupt-controller;
            #interrupt-cells = <0x2>;
            num-pins = <0xD>;
