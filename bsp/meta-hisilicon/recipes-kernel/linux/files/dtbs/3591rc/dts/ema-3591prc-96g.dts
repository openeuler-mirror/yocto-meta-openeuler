				index = <0x01>;
				src_bit = <0x02>;
				compatible = "HiIPCV230,rx-mailbox-fast";
				des_remote_processor = "RX_DES_ISP1_IPC1_ID7_MBX1";
				src_remote_processor = "IPC_ISP1_IPC1_MBX1_RPID0_Q_RX_ACPU0";
				irq_affinity = <0x0b>;
			};

			mailbox-8-acpu0-tx-isp1-ipc1-3 {
				func = <0x01 0x01 0x00>;
				des_bit = <0x03>;
				index = <0x08>;
				src_bit = <0x00>;
				compatible = "HiIPCV230,tx-mailbox-fast";
				des_remote_processor = "IPC_ISP1_IPC1_MBX8_RPID0_Q_TX_ACPU0";
				src_remote_processor = "TX_SRC_ISP1_IPC1_ID7_MBX8";
			};

			mailbox-2-isp1-ipc1-3-rx-acpu0 {
				interrupts = <0x00 0x130 0x04>;
				func = <0x01 0x00 0x01>;
				des_bit = <0x00>;
				index = <0x02>;
				src_bit = <0x03>;
				compatible = "HiIPCV230,rx-mailbox-fast";
				des_remote_processor = "RX_DES_ISP1_IPC1_ID7_MBX2";
				src_remote_processor = "IPC_ISP1_IPC1_MBX2_RPID0_Q_RX_ACPU0";
				irq_affinity = <0x0b>;
			};
