	rdr {
		compatible = "hisilicon,rdr";
		wait-dumplog-timeout = <0x7530>;
		reg = <0x00 0x2f900000 0x00 0x1900000>;
		status = "ok";
		rdr_area_num = <0x0a>;
		device_flag = <0x01>;
		rdr_area_names = "AP\0DVPP\0DRIVER\0DP\0TS\0TF\0TEEOS\0HSM\0LPM\0BIOS";
		rdr_area_sizes = <0x00 0x40000 0x40000 0x500000 0x200000 0x10000 0x20000 0x50000 0x90000 0x50000>;
	};

	hisi_ipc_device_0 {
		ipc_id = <0x00>;
		#size-cells = <0x02>;
		compatible = "hisi,hi-miniv2-ipcdrv";
		ranges;
		mailboxes = <0x50>;
		#address-cells = <0x02>;

		tsc-p0@BA0A0000 {
			interrupts = <0x00 0xe0 0x04 0x00 0xe1 0x04 0x00 0xe2 0x04 0x00 0xe3 0x04>;
			capability = <0x08>;
			#size-cells = <0x02>;
			compatible = "HiIPCV230,hisi-ipc-tsc";
			reg = <0x00 0xba0a0000 0x00 0xb000>;
			mailboxes = <0x08>;
			#address-cells = <0x02>;
			unlock_key = <0x1acce551>;

			mailbox-8-tsc-rx-acpu3 {
				interrupts = <0x00 0xe3 0x04>;
				func = <0x00 0x00 0x01>;
				des_bit = <0x07>;
				index = <0x08>;
				src_bit = <0x03>;
				compatible = "HiIPCV230,rx-mailbox-normal";
				des_remote_processor = "HI1910P_AICPU3_MBX1";
				src_remote_processor = "MDC_IPC_TSC_MBX8_RPID7_RX_ACPU3";
			};

			mailbox-1-acpu0-tx-tsc {
				func = <0x00 0x01 0x00>;
				des_bit = <0x00>;
				index = <0x01>;
				src_bit = <0x04>;
				compatible = "HiIPCV230,tx-mailbox-normal";
				des_remote_processor = "MDC_IPC_TSC_MBX1_RPID0_TX_ACPU0";
				src_remote_processor = "HI1910P_AICPU0_MBX1";
			};

			mailbox-3-acpu2-tx-tsc {
				func = <0x00 0x01 0x00>;
				des_bit = <0x02>;
				index = <0x03>;
				src_bit = <0x06>;
				compatible = "HiIPCV230,tx-mailbox-normal";
				des_remote_processor = "MDC_IPC_TSC_MBX3_RPID2_TX_ACPU2";
				src_remote_processor = "HI1910P_AICPU2_MBX3";
			};

			mailbox-5-tsc-rx-acpu0 {
				interrupts = <0x00 0xe0 0x04>;
				func = <0x00 0x00 0x01>;
				des_bit = <0x04>;
				index = <0x05>;
				src_bit = <0x00>;
				compatible = "HiIPCV230,rx-mailbox-normal";
				des_remote_processor = "HI1910P_AICPU0_MBX5";
				src_remote_processor = "MDC_IPC_TSC_MBX5_RPID4_RX_ACPU0";
			};

			mailbox-7-tsc-rx-acpu2 {
				interrupts = <0x00 0xe2 0x04>;
				func = <0x00 0x00 0x01>;
				des_bit = <0x06>;
				index = <0x07>;
				src_bit = <0x02>;
				compatible = "HiIPCV230,rx-mailbox-normal";
				des_remote_processor = "HI1910P_AICPU2_MBX7";
				src_remote_processor = "MDC_IPC_TSC_MBX7_RPID6_RX_ACPU2";
			};

			mailbox-6-tsc-rx-acpu1 {
				interrupts = <0x00 0xe1 0x04>;
				func = <0x00 0x00 0x01>;
				des_bit = <0x05>;
				index = <0x06>;
				src_bit = <0x01>;
				compatible = "HiIPCV230,rx-mailbox-normal";
				des_remote_processor = "HI1910P_AICPU1_MBX6";
				src_remote_processor = "MDC_IPC_TSC_MBX6_RPID5_RX_ACPU1";
			};

			mailbox-2-acpu1-tx-tsc {
				func = <0x00 0x01 0x00>;
				des_bit = <0x01>;
				index = <0x02>;
				src_bit = <0x05>;
				compatible = "HiIPCV230,tx-mailbox-normal";
				des_remote_processor = "MDC_IPC_TSC_MBX2_RPID1_TX_ACPU1";
				src_remote_processor = "HI1910P_AICPU1_MBX2";
			};

			mailbox-4-acpu3-tx-tsc {
				func = <0x00 0x01 0x00>;
				des_bit = <0x03>;
				index = <0x04>;
				src_bit = <0x07>;
				compatible = "HiIPCV230,tx-mailbox-normal";
				des_remote_processor = "MDC_IPC_TSC_MBX4_RPID3_TX_ACPU3";
				src_remote_processor = "HI1910P_AICPU3_MBX4";
			};
		};

		cluster3-p0@AB730000 {
			interrupts = <0x00 0x121 0x04 0x00 0x121 0x04 0x00 0x121 0x04 0x00 0x121 0x04>;
			capability = <0x08>;
			#size-cells = <0x02>;
