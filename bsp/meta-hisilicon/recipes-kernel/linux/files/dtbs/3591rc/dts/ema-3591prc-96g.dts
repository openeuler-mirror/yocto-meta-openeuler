/dts-v1/;

/ {
	#size-cells = <0x02>;
	compatible = "hisilicon,hi1910p-evb\0hisilicon,ascend610";
	model = "asic";
	#address-cells = <0x02>;
	aicpu_partial_good_enable = <0x00>;
	interrupt-parent = <0x01>;
	hisi,boardid = <0x00 0x02 0x01 0x04>;

	chosen {
		bootargs = "console=ttyAMA0,115200 crashkernel=200M rw rdinit=/sbin/init root=/dev/mmcblk0p1 selinux=0 systemd.debug_shell syslog no_console_suspend fbcon=map:3 earlycon=pl011,mmio32,0x840c0000 initrd=0x880002100,450M rootwait log_redirect=0x1fc000@0xb101000 cma=256M default_hugepagesz=2M panic=3 ascend_enable_all sbsa_gwdt.action=2 watchdog.sysfs_write=1  hardlockup_cpu_freq=1900000 coredump_filter=0x31 enable_ascend_share_pool enable_sp_multi_group_mode bootdot=0x1C8@0x312F1108 osname=AOS_DP hugevmalloc=on runImgLocation=0x0 reboot_reason=DEVICE_COLDBOOT";
	};

	i2c@00_A218_0000 {
		interrupts = <0x00 0x100 0x04>;
		i2c-scl-falling-time-ns = <0x122>;
		clock-frequency = <0x186a0>;
		#size-cells = <0x00>;
		compatible = "snps,designware-i2c";
		reg = <0x00 0xa2180000 0x00 0x10000>;
		status = "ok";
		pinctrl-1 = <0x1a 0x1b 0x18 0x19>;
		#address-cells = <0x01>;
		i2c-sda-hold-time-ns = <0x190>;
		pinctrl-names = "default\0idle";
		i2c-sda-falling-time-ns = <0x3b2>;
		pinctrl-0 = <0x16 0x17 0x18 0x19>;
		clocks = <0x2f>;

		tmp451@4c {
			#thermal-sensor-cells = <0x01>;
			compatible = "ti,tmp451";
			reg = <0x4c>;
			status = "okay";
		};

		pcf8563@51 {
			#clock-cells = <0x00>;
			compatible = "nxp,pcf8563";
			reg = <0x51>;
		};
	};

	alg_clk {
		#clock-cells = <0x00>;
		phandle = <0x0d>;
		clock-frequency = <0xbebc200>;
		compatible = "fixed-clock";
	};

	interrupt-controller@85000000 {
		interrupt-controller;
		interrupts = <0x01 0x09 0xff04>;
		#redistributor-regions = <0x01>;
		phandle = <0x01>;
		redistributor-stride = <0x00 0x40000>;
		#size-cells = <0x02>;
		compatible = "arm,gic-v3";
		ranges;
		reg = <0x00 0x85000000 0x00 0x10000 0x00 0x85100000 0x00 0x800000>;
		#interrupt-cells = <0x03>;
		#address-cells = <0x02>;
		linux,phandle = <0x01>;

		interrupt-controller@87000000 {
			msi-controller;
			#msi-cells = <0x01>;
			phandle = <0x02>;
			compatible = "arm,gic-v3-its";
			reg = <0x00 0x87000000 0x00 0x40000>;
		};
	};

