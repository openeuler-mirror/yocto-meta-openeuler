-    if (strncmp(SENSOR_NAME_HY_S0603, name, len) == 0) {
+    if ((strncmp(SENSOR_NAME_OS08A20, name, len) == 0) ||
+        (strncmp(SENSOR_NAME_OS04A10, name, len) == 0)) {
+        clock = 0x4001; /* 0x4001: 24MHz */
+    } else if ((strncmp(SENSOR_NAME_HY_S0603, name, len) == 0) || 
+        (strncmp(SENSOR_NAME_SC450AI, name, len) == 0)) {
         clock = 0xA001; /* 0xA001: 27MHz */
