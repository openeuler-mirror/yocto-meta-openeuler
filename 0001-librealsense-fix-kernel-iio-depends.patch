From ab961b37834894cc25ff202081a6623d8e8b35b2 Mon Sep 17 00:00:00 2001
From: fanglinxu <fanglinxu@huawei.com>
Date: Mon, 2 Mar 2026 19:56:42 +0800
Subject: [PATCH] librealsense: fix kernel iio depends

* hid.cfg from upstream is not full complete, need iio modules

Signed-off-by: fanglinxu <fanglinxu@huawei.com>
---
 .../features/3rd_drivers/librealsense/librealsense.cfg         | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/meta-openeuler/recipes-kernel/linux/files/meta-data/features/3rd_drivers/librealsense/librealsense.cfg b/meta-openeuler/recipes-kernel/linux/files/meta-data/features/3rd_drivers/librealsense/librealsense.cfg
index 0711e9959be..9a178758864 100644
--- a/meta-openeuler/recipes-kernel/linux/files/meta-data/features/3rd_drivers/librealsense/librealsense.cfg
+++ b/meta-openeuler/recipes-kernel/linux/files/meta-data/features/3rd_drivers/librealsense/librealsense.cfg
@@ -1,3 +1,6 @@
+# ref's cfg depend on iio
+CONFIG_IIO=m
+
 # ref https://github.com/realsenseai/meta-intel-realsense/blob/honister/recipes-kernel/linux/files/hid.cfg
 # hid.cfg
 CONFIG_IIO_BUFFER=y
-- 
2.34.1

